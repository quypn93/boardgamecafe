@model List<EscapeRoomFinder.Models.ViewModels.CityBlogItem>
@{
    ViewData["Title"] = "Escape Rooms by City";
    ViewData["Description"] = "Find the best escape rooms in cities worldwide. Browse our directory of escape room venues organized by city and discover your next adventure.";
    var countries = ViewBag.Countries as List<string> ?? new List<string>();
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 fw-bold">Escape Rooms by City</h1>
            <p class="lead text-muted">Discover the best escape room experiences in cities around the world</p>
        </div>
    </div>

    <!-- Country Filter -->
    <div class="row mb-4">
        <div class="col-md-4">
            <form method="get">
                <div class="input-group">
                    <select name="country" class="form-select" onchange="this.form.submit()">
                        <option value="">All Countries</option>
                        @foreach (var country in countries)
                        {
                            if (ViewBag.SelectedCountry == country)
                            {
                                <option value="@country" selected>@country</option>
                            }
                            else
                            {
                                <option value="@country">@country</option>
                            }
                        }
                    </select>
                    @if (!string.IsNullOrEmpty(ViewBag.SelectedCountry))
                    {
                        <a href="/cities" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
        <div class="col-md-8 text-md-end">
            <span class="text-muted">@ViewBag.TotalCities cities found</span>
        </div>
    </div>

    <!-- City Cards -->
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <a href="/escape-rooms-in/@item.Slug" class="text-decoration-none">
                    <div class="card h-100 shadow-sm hover-shadow">
                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(item.SampleImageUrl))
                            {
                                <img src="@item.SampleImageUrl" class="card-img-top" alt="Escape rooms in @item.City" style="height: 180px; object-fit: cover;">
                            }
                            else
                            {
                                <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 180px;">
                                    <i class="bi bi-door-closed text-white" style="font-size: 4rem;"></i>
                                </div>
                            }
                            <span class="position-absolute top-0 end-0 badge bg-primary m-2">@item.Country</span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title text-dark">@item.City</h5>
                            <div class="d-flex justify-content-between text-muted small">
                                <span><i class="bi bi-building"></i> @item.VenueCount venues</span>
                                <span><i class="bi bi-door-closed"></i> @item.TotalRooms rooms</span>
                            </div>
                            @if (item.AverageRating.HasValue)
                            {
                                <div class="mt-2">
                                    <span class="text-warning">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= Math.Round(item.AverageRating.Value))
                                            {
                                                <i class="bi bi-star-fill"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-star"></i>
                                            }
                                        }
                                    </span>
                                    <span class="text-muted ms-1">@item.AverageRating.Value.ToString("F1")</span>
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-transparent border-0">
                            <span class="text-primary">View escape rooms <i class="bi bi-arrow-right"></i></span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-geo-alt display-1 text-muted"></i>
            <h3 class="mt-3">No cities found</h3>
            <p class="text-muted">We're still building our escape room directory. Check back soon!</p>
        </div>
    }

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    var isActive = i == ViewBag.Page;
                    <li class="page-item @(isActive ? "active" : "")">
                        <a class="page-link" href="/cities?page=@i@(string.IsNullOrEmpty(ViewBag.SelectedCountry) ? "" : "&country=" + ViewBag.SelectedCountry)">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        transition: all 0.3s ease;
    }
    .card {
        transition: all 0.3s ease;
    }
</style>
