@model EscapeRoomFinder.Models.ViewModels.CityGuideViewModel
@{
    ViewData["Title"] = $"Best Escape Rooms in {Model.City} - {Model.Country}";
    ViewData["Description"] = $"Discover the best escape rooms in {Model.City}, {Model.Country}. Browse {Model.Venues.Count} venues with {Model.TotalRooms} rooms. Read reviews and book your next escape room adventure.";
    var slug = Model.City.ToLower().Replace(" ", "-").Replace("'", "");
}

<!-- SEO Structured Data -->
<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "ItemList",
    "name": "Escape Rooms in @Model.City",
    "description": "Best escape rooms in @Model.City, @Model.Country",
    "numberOfItems": @Model.Venues.Count,
    "itemListElement": [
        @for (int i = 0; i < Math.Min(Model.Venues.Count, 10); i++)
        {
            var venue = Model.Venues[i];
            <text>
        {
            "@@type": "ListItem",
            "position": @(i + 1),
            "item": {
                "@@type": "LocalBusiness",
                "name": "@venue.Name.Replace("\"", "\\\"")",
                "address": "@venue.Address.Replace("\"", "\\\"")"
            }
        }@(i < Math.Min(Model.Venues.Count, 10) - 1 ? "," : "")
            </text>
        }
    ]
}
</script>

<div class="bg-dark text-white py-5">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-white-50">Home</a></li>
                <li class="breadcrumb-item"><a href="/cities" class="text-white-50">Cities</a></li>
                <li class="breadcrumb-item active text-white">@Model.City</li>
            </ol>
        </nav>
        <h1 class="display-4 fw-bold">Escape Rooms in @Model.City</h1>
        <p class="lead">@Model.Country</p>
        <div class="d-flex flex-wrap gap-4 mt-4">
            <div>
                <span class="h3 fw-bold">@Model.Venues.Count</span>
                <span class="text-white-50 ms-2">Venues</span>
            </div>
            <div>
                <span class="h3 fw-bold">@Model.TotalRooms</span>
                <span class="text-white-50 ms-2">Escape Rooms</span>
            </div>
            @if (Model.AverageRating.HasValue)
            {
                <div>
                    <span class="h3 fw-bold text-warning">@Model.AverageRating.Value.ToString("F1")</span>
                    <span class="text-white-50 ms-2">Avg Rating</span>
                </div>
            }
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row">
        <!-- Main Content -->
        <div class="col-lg-8">
            <h2 class="mb-4">All Escape Room Venues in @Model.City</h2>

            @foreach (var venue in Model.Venues)
            {
                <div class="card mb-4 shadow-sm">
                    <div class="row g-0">
                        <div class="col-md-4">
                            @if (!string.IsNullOrEmpty(venue.LocalImagePath))
                            {
                                <img src="@venue.LocalImagePath" class="img-fluid rounded-start h-100" style="object-fit: cover;" alt="@venue.Name">
                            }
                            else
                            {
                                <div class="bg-secondary d-flex align-items-center justify-content-center h-100 rounded-start" style="min-height: 200px;">
                                    <i class="bi bi-door-closed text-white" style="font-size: 3rem;"></i>
                                </div>
                            }
                        </div>
                        <div class="col-md-8">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h5 class="card-title mb-1">
                                        <a href="/venue/@venue.Slug" class="text-decoration-none text-dark">@venue.Name</a>
                                    </h5>
                                    @if (venue.AverageRating.HasValue)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-star-fill"></i> @venue.AverageRating.Value.ToString("F1")
                                        </span>
                                    }
                                </div>
                                <p class="text-muted small mb-2">
                                    <i class="bi bi-geo-alt"></i> @venue.Address
                                </p>
                                @if (!string.IsNullOrEmpty(venue.Description))
                                {
                                    <p class="card-text">@(venue.Description.Length > 150 ? venue.Description.Substring(0, 150) + "..." : venue.Description)</p>
                                }
                                <div class="d-flex flex-wrap gap-2 mb-3">
                                    <span class="badge bg-primary">@venue.Rooms.Count rooms</span>
                                    @if (venue.TotalReviews > 0)
                                    {
                                        <span class="badge bg-secondary">@venue.TotalReviews reviews</span>
                                    }
                                    @if (!string.IsNullOrEmpty(venue.PriceRange))
                                    {
                                        <span class="badge bg-info">@venue.PriceRange</span>
                                    }
                                </div>
                                <div class="d-flex gap-2">
                                    <a href="/venue/@venue.Slug" class="btn btn-primary btn-sm">View Details</a>
                                    @if (!string.IsNullOrEmpty(venue.Website))
                                    {
                                        <a href="@venue.Website" target="_blank" rel="noopener" class="btn btn-outline-secondary btn-sm">
                                            <i class="bi bi-globe"></i> Website
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Quick Stats -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-bar-chart"></i> Quick Stats
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span>Total Venues</span>
                            <strong>@Model.Venues.Count</strong>
                        </li>
                        <li class="d-flex justify-content-between py-2 border-bottom">
                            <span>Total Rooms</span>
                            <strong>@Model.TotalRooms</strong>
                        </li>
                        @if (Model.AverageRating.HasValue)
                        {
                            <li class="d-flex justify-content-between py-2 border-bottom">
                                <span>Average Rating</span>
                                <strong class="text-warning"><i class="bi bi-star-fill"></i> @Model.AverageRating.Value.ToString("F1")</strong>
                            </li>
                        }
                        <li class="d-flex justify-content-between py-2">
                            <span>Total Reviews</span>
                            <strong>@Model.Venues.Sum(v => v.TotalReviews)</strong>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Related Cities -->
            @if (Model.RelatedCities.Any())
            {
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="bi bi-geo-alt"></i> Other Cities in @Model.Country
                    </div>
                    <div class="list-group list-group-flush">
                        @foreach (var city in Model.RelatedCities)
                        {
                            <a href="/escape-rooms-in/@city.Slug" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                @city.City
                                <span class="badge bg-primary rounded-pill">@city.VenueCount</span>
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- CTA -->
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <i class="bi bi-building display-4"></i>
                    <h5 class="mt-3">Own an escape room in @Model.City?</h5>
                    <p class="small">List your venue for free and reach thousands of escape room enthusiasts.</p>
                    <a href="/for-business" class="btn btn-light">Add Your Venue</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SEO Content -->
<div class="bg-light py-5">
    <div class="container">
        <h2>About Escape Rooms in @Model.City</h2>
        <p>Looking for the best escape room experience in @Model.City, @Model.Country? You've come to the right place!
        Our directory features @Model.Venues.Count escape room venues with a total of @Model.TotalRooms unique escape rooms to choose from.</p>

        <p>Whether you're a first-time player or an experienced escape artist, @Model.City offers a variety of themes and
        difficulty levels to suit everyone. From mystery and horror to adventure and sci-fi, there's an escape room
        waiting for you.</p>

        <h3 class="mt-4">Tips for Escape Rooms in @Model.City</h3>
        <ul>
            <li>Book in advance, especially for weekends and holidays</li>
            <li>Arrive 15 minutes early to complete waivers and get briefed</li>
            <li>Bring a group of 2-6 people for the best experience</li>
            <li>Communicate with your team and share your findings</li>
            <li>Don't be afraid to ask for hints if you get stuck</li>
        </ul>
    </div>
</div>
