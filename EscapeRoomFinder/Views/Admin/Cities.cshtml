@model List<EscapeRoomFinder.Models.Domain.City>
@{
    ViewData["Title"] = "City Management";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-geo-alt me-2"></i>City Management</h1>
    <div>
        <button type="button" class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#addCityModal">
            <i class="bi bi-plus-lg"></i> Add City
        </button>
        <button type="button" class="btn btn-primary" onclick="seedCities()">
            <i class="bi bi-database"></i> Seed Default Cities
        </button>
    </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-md-2">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h3>@ViewBag.TotalCities</h3>
                <small>Total Cities</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card bg-warning text-dark">
            <div class="card-body text-center">
                <h3>@ViewBag.NeverCrawled</h3>
                <small>Never Crawled</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h3>@ViewBag.FailedCities</h3>
                <small>Failed</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h3>@ViewBag.PendingRetry</h3>
                <small>Pending Retry</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card bg-secondary text-white">
            <div class="card-body text-center">
                <h3>@ViewBag.USCount</h3>
                <small>US Cities</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card bg-dark text-white">
            <div class="card-body text-center">
                <h3>@ViewBag.InternationalCount</h3>
                <small>International</small>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <select name="status" class="form-select" onchange="this.form.submit()">
                    <option value="">All</option>
                    @if (ViewBag.Status == "never") { <option value="never" selected>Never Crawled</option> } else { <option value="never">Never Crawled</option> }
                    @if (ViewBag.Status == "failed") { <option value="failed" selected>Failed</option> } else { <option value="failed">Failed</option> }
                    @if (ViewBag.Status == "pending") { <option value="pending" selected>Pending Retry</option> } else { <option value="pending">Pending Retry</option> }
                    @if (ViewBag.Status == "inactive") { <option value="inactive" selected>Inactive</option> } else { <option value="inactive">Inactive</option> }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Region</label>
                <select name="region" class="form-select" onchange="this.form.submit()">
                    <option value="">All Regions</option>
                    @if (ViewBag.Region == "US") { <option value="US" selected>US</option> } else { <option value="US">US</option> }
                    @if (ViewBag.Region == "International") { <option value="International" selected>International</option> } else { <option value="International">International</option> }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Search</label>
                <input type="text" name="search" class="form-control" placeholder="City or Country..." value="@ViewBag.Search" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Bulk Actions -->
<div class="mb-3">
    <button type="button" class="btn btn-success" id="bulkCrawlBtn" disabled onclick="bulkCrawl()">
        <i class="bi bi-cloud-download"></i> Crawl Selected (<span id="selectedCount">0</span>)
    </button>
</div>

<!-- Cities Table -->
<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th><input type="checkbox" id="selectAll" onclick="toggleSelectAll()" /></th>
                    <th>City</th>
                    <th>Country</th>
                    <th>Region</th>
                    <th>Crawl Count</th>
                    <th>Last Crawled</th>
                    <th>Status</th>
                    <th>Max Results</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var city in Model)
                {
                    <tr id="city-row-@city.CityId" class="@(!city.IsActive ? "table-secondary" : "")">
                        <td>
                            <input type="checkbox" class="city-checkbox" value="@city.CityId" onchange="updateSelectedCount()" />
                        </td>
                        <td>
                            @city.Name
                            @if (!city.IsActive)
                            {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>@city.Country</td>
                        <td>
                            <span class="badge @(city.Region == "US" ? "bg-primary" : "bg-info")">@city.Region</span>
                        </td>
                        <td>@city.CrawlCount</td>
                        <td>
                            @if (city.LastCrawledAt.HasValue)
                            {
                                @city.LastCrawledAt.Value.ToString("MMM dd, yyyy HH:mm")
                            }
                            else
                            {
                                <span class="text-muted">Never</span>
                            }
                        </td>
                        <td>
                            @if (city.LastCrawlStatus == "Success")
                            {
                                <span class="badge bg-success">Success</span>
                            }
                            else if (city.LastCrawlStatus == "Failed")
                            {
                                <span class="badge bg-danger">Failed</span>
                                @if (city.NextCrawlAt.HasValue)
                                {
                                    <br /><small class="text-muted">Retry: @city.NextCrawlAt.Value.ToString("HH:mm")</small>
                                }
                            }
                            else if (city.LastCrawlStatus == "InProgress")
                            {
                                <span class="badge bg-warning">In Progress</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm" style="width: 70px;"
                                   value="@city.MaxResults" min="5" max="50"
                                   onchange="updateMaxResults(@city.CityId, this.value)" />
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <button type="button" class="btn btn-outline-primary" title="Crawl Now"
                                        onclick="crawlCity(@city.CityId, '@city.Name.Replace("'", "\\'")')">
                                    <i class="bi bi-cloud-download"></i>
                                </button>
                                <button type="button" class="btn btn-outline-@(city.IsActive ? "warning" : "success")"
                                        title="@(city.IsActive ? "Deactivate" : "Activate")"
                                        onclick="toggleActive(@city.CityId)">
                                    <i class="bi bi-@(city.IsActive ? "pause" : "play")"></i>
                                </button>
                                @if (city.LastCrawlStatus == "Failed")
                                {
                                    <button type="button" class="btn btn-outline-info" title="Reset Status"
                                            onclick="resetStatus(@city.CityId)">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                }
                                <button type="button" class="btn btn-outline-danger" title="Delete"
                                        onclick="deleteCity(@city.CityId, '@city.Name.Replace("'", "\\'")')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Pagination -->
@if (ViewBag.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="?page=@i&status=@ViewBag.Status&region=@ViewBag.Region&search=@ViewBag.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
}

<!-- Add City Modal -->
<div class="modal fade" id="addCityModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add City</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">City Name</label>
                    <input type="text" id="newCityName" class="form-control" placeholder="e.g. New York" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Country</label>
                    <input type="text" id="newCityCountry" class="form-control" placeholder="e.g. United States" value="United States" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Region</label>
                    <select id="newCityRegion" class="form-select">
                        <option value="US">US</option>
                        <option value="International">International</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addCity()">Add City</button>
            </div>
        </div>
    </div>
</div>

<!-- Crawl Progress Modal -->
<div class="modal fade" id="crawlProgressModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-cloud-download me-2"></i>Crawling...</h5>
            </div>
            <div class="modal-body text-center">
                <div class="spinner-border text-primary mb-3" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p id="crawlProgressText">Crawling city...</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function toggleSelectAll() {
        const checked = document.getElementById('selectAll').checked;
        document.querySelectorAll('.city-checkbox').forEach(cb => cb.checked = checked);
        updateSelectedCount();
    }

    function updateSelectedCount() {
        const count = document.querySelectorAll('.city-checkbox:checked').length;
        document.getElementById('selectedCount').textContent = count;
        document.getElementById('bulkCrawlBtn').disabled = count === 0;
    }

    async function crawlCity(cityId, cityName) {
        if (!confirm(`Start crawling "${cityName}"?`)) return;

        const modal = new bootstrap.Modal(document.getElementById('crawlProgressModal'));
        document.getElementById('crawlProgressText').textContent = `Crawling ${cityName}...`;
        modal.show();

        try {
            const response = await fetch(`/admin/cities/crawl/${cityId}`, { method: 'POST' });
            const result = await response.json();
            modal.hide();

            if (result.success) {
                alert(result.message);
                location.reload();
            } else {
                alert('Error: ' + result.message);
            }
        } catch (error) {
            modal.hide();
            alert('Error: ' + error.message);
        }
    }

    async function bulkCrawl() {
        const checkboxes = document.querySelectorAll('.city-checkbox:checked');
        const cityIds = Array.from(checkboxes).map(cb => parseInt(cb.value));

        if (cityIds.length === 0) {
            alert('No cities selected.');
            return;
        }

        if (!confirm(`Start crawling ${cityIds.length} cities? This may take a while.`)) return;

        const modal = new bootstrap.Modal(document.getElementById('crawlProgressModal'));
        document.getElementById('crawlProgressText').textContent = `Crawling ${cityIds.length} cities...`;
        modal.show();

        try {
            const response = await fetch('/admin/cities/bulk-crawl', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(cityIds)
            });
            const result = await response.json();
            modal.hide();

            if (result.success) {
                const summary = result.results.map(r =>
                    `${r.city}: ${r.success ? `Added ${r.venuesAdded}` : r.error}`
                ).join('\n');
                alert('Crawl completed!\n\n' + summary);
                location.reload();
            } else {
                alert('Error: ' + result.message);
            }
        } catch (error) {
            modal.hide();
            alert('Error: ' + error.message);
        }
    }

    async function toggleActive(cityId) {
        try {
            const response = await fetch(`/admin/cities/toggle-active/${cityId}`, { method: 'POST' });
            const result = await response.json();
            if (result.success) {
                location.reload();
            } else {
                alert('Error: ' + result.message);
            }
        } catch (error) {
            alert('Error: ' + error.message);
        }
    }

    async function updateMaxResults(cityId, value) {
        try {
            const response = await fetch(`/admin/cities/update-max-results/${cityId}?maxResults=${value}`, { method: 'POST' });
            const result = await response.json();
            if (!result.success) {
                alert('Error: ' + result.message);
            }
        } catch (error) {
            alert('Error: ' + error.message);
        }
    }

    async function resetStatus(cityId) {
        try {
            const response = await fetch(`/admin/cities/reset-status/${cityId}`, { method: 'POST' });
            const result = await response.json();
            if (result.success) {
                location.reload();
            } else {
                alert('Error: ' + result.message);
            }
        } catch (error) {
            alert('Error: ' + error.message);
        }
    }

    async function deleteCity(cityId, cityName) {
        if (!confirm(`Delete "${cityName}" and all its crawl history?`)) return;

        try {
            const response = await fetch(`/admin/cities/delete/${cityId}`, { method: 'POST' });
            const result = await response.json();
            if (result.success) {
                document.getElementById(`city-row-${cityId}`).remove();
            } else {
                alert('Error: ' + result.message);
            }
        } catch (error) {
            alert('Error: ' + error.message);
        }
    }

    async function addCity() {
        const name = document.getElementById('newCityName').value.trim();
        const country = document.getElementById('newCityCountry').value.trim();
        const region = document.getElementById('newCityRegion').value;

        if (!name || !country) {
            alert('Please enter both city name and country.');
            return;
        }

        try {
            const response = await fetch(`/admin/cities/add?name=${encodeURIComponent(name)}&country=${encodeURIComponent(country)}&region=${region}`, { method: 'POST' });
            const result = await response.json();
            if (result.success) {
                bootstrap.Modal.getInstance(document.getElementById('addCityModal')).hide();
                location.reload();
            } else {
                alert('Error: ' + result.message);
            }
        } catch (error) {
            alert('Error: ' + error.message);
        }
    }

    async function seedCities() {
        if (!confirm('Seed default cities? This will add 170+ cities if not already present.')) return;

        try {
            const response = await fetch('/admin/cities/seed', { method: 'POST' });
            const result = await response.json();
            alert(result.message);
            location.reload();
        } catch (error) {
            alert('Error: ' + error.message);
        }
    }
</script>
}
