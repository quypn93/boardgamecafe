@{
    ViewData["Title"] = "For Business - List Your Escape Room";
    ViewData["Description"] = "Add your escape room venue to our directory. Reach thousands of escape room enthusiasts and grow your business.";
}

<div class="bg-primary text-white py-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">Grow Your Escape Room Business</h1>
        <p class="lead">Join thousands of venues on Escape Room Finder and reach enthusiasts looking for their next adventure</p>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 text-center border-0 shadow-sm">
                <div class="card-body">
                    <div class="display-4 text-primary mb-3">
                        <i class="bi bi-people"></i>
                    </div>
                    <h4>Reach More Players</h4>
                    <p class="text-muted">Get discovered by thousands of escape room enthusiasts searching for their next adventure in your city.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 text-center border-0 shadow-sm">
                <div class="card-body">
                    <div class="display-4 text-primary mb-3">
                        <i class="bi bi-star"></i>
                    </div>
                    <h4>Showcase Reviews</h4>
                    <p class="text-muted">Build trust with authentic reviews from players. Let your reputation speak for itself.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 text-center border-0 shadow-sm">
                <div class="card-body">
                    <div class="display-4 text-primary mb-3">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <h4>Drive Bookings</h4>
                    <p class="text-muted">Convert browsers into bookers with detailed room listings and direct links to your booking system.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-light py-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2>Free Basic Listing</h2>
                <p class="lead">Every escape room venue can be listed on our platform for free.</p>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i> Basic venue information</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i> Contact details & website link</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i> Customer reviews display</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i> Map location</li>
                    <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i> Room listings</li>
                </ul>
                <a href="/listing/claim" class="btn btn-primary btn-lg">Claim Your Free Listing</a>
            </div>
            <div class="col-lg-6">
                <div class="card border-primary">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-star-fill me-2"></i>Premium Listing</h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Stand out from the competition with premium features:</p>
                        <ul class="list-unstyled">
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> <strong>Featured placement</strong> in search results</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> <strong>Premium badge</strong> on your listing</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> <strong>Photo gallery</strong> for your rooms</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> <strong>Direct booking link</strong> integration</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> <strong>Analytics dashboard</strong> for your listing</li>
                            <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> <strong>Priority support</strong></li>
                        </ul>
                        <a href="/listing/pricing" class="btn btn-outline-primary w-100">View Premium Plans</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto text-center">
            <h2>Ready to Get Started?</h2>
            <p class="lead text-muted mb-4">Join our directory today and start reaching more escape room enthusiasts.</p>
            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
                <a href="/listing/claim" class="btn btn-primary btn-lg">
                    <i class="bi bi-building me-2"></i>Claim Your Listing
                </a>
                <a href="mailto:support@escaperoomfinder.com" class="btn btn-outline-secondary btn-lg">
                    <i class="bi bi-envelope me-2"></i>Contact Us
                </a>
            </div>
        </div>
    </div>
</div>

<div class="bg-dark text-white py-5">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <h3 class="text-center mb-4">Frequently Asked Questions</h3>
                <div class="accordion accordion-flush" id="faqAccordion">
                    <div class="accordion-item bg-dark">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-dark text-white" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                                How do I add my escape room to the directory?
                            </button>
                        </h2>
                        <div id="faq1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted">
                                Click the "Claim Your Listing" button and follow the simple steps to add your venue. If your venue is already listed, you can claim it by verifying ownership.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-dark">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-dark text-white" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                                Is the basic listing really free?
                            </button>
                        </h2>
                        <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted">
                                Yes! Basic listings are completely free and include all essential information about your venue, rooms, and customer reviews.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-dark">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-dark text-white" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                                How can I update my venue information?
                            </button>
                        </h2>
                        <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted">
                                Once you've claimed your listing, you can log in to update your venue information at any time. Premium users get additional editing features.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item bg-dark">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed bg-dark text-white" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                                Can I respond to customer reviews?
                            </button>
                        </h2>
                        <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                            <div class="accordion-body text-muted">
                                Yes, claimed listing owners can respond to reviews, helping build trust and engagement with your customers.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
