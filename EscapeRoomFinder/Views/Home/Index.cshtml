@model VenueSearchPagedResult
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<EscapeRoomFinder.SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["Home_Title"].Value;
    ViewData["Description"] = SharedLocalizer["Home_Subtitle"].Value;
}

<div class="bg-dark text-light py-5 mb-4">
    <div class="container">
        <h1 class="display-4 text-center mb-4">
            <i class="bi bi-door-open"></i> @SharedLocalizer["Home_HeroTitle"]
        </h1>
        <p class="lead text-center text-muted mb-4">
            @string.Format(SharedLocalizer["Home_HeroSubtitle"].Value, ViewBag.TotalVenues, ViewBag.TotalRooms)
        </p>

        <form method="get" class="row g-3 justify-content-center">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" name="query" placeholder="@SharedLocalizer["Home_SearchPlaceholder"]" value="@ViewBag.Query" />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-select" name="city">
                    <option value="">@SharedLocalizer["Home_AllCities"]</option>
                    @foreach (var city in ViewBag.Cities as List<string> ?? new List<string>())
                    {
                        <option value="@city" selected="@(ViewBag.City == city)">@city</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select" name="theme">
                    <option value="">@SharedLocalizer["Home_AllThemes"]</option>
                    @foreach (var theme in ViewBag.Themes as List<string> ?? new List<string>())
                    {
                        <option value="@theme" selected="@(ViewBag.Theme == theme)">@theme</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> @SharedLocalizer["Home_SearchButton"]
                </button>
            </div>
        </form>

        <div class="row g-2 justify-content-center mt-3">
            <div class="col-auto">
                <button type="button" class="btn btn-outline-light btn-sm" data-bs-toggle="collapse" data-bs-target="#advancedFilters">
                    <i class="bi bi-sliders"></i> @SharedLocalizer["Home_AdvancedFilters"]
                </button>
            </div>
            <div class="col-auto">
                <a href="/map" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-map"></i> @SharedLocalizer["Home_ViewMap"]
                </a>
            </div>
        </div>

        <div class="collapse mt-3" id="advancedFilters">
            <form method="get" class="row g-2 justify-content-center bg-secondary bg-opacity-25 p-3 rounded">
                <input type="hidden" name="query" value="@ViewBag.Query" />
                <input type="hidden" name="city" value="@ViewBag.City" />
                <input type="hidden" name="theme" value="@ViewBag.Theme" />
                <div class="col-md-2">
                    <label class="form-label small">@SharedLocalizer["Home_Difficulty"]</label>
                    <select class="form-select form-select-sm" name="minDifficulty">
                        <option value="">@SharedLocalizer["Home_Any"]</option>
                        <option value="1">1 - @SharedLocalizer["Home_VeryEasy"]</option>
                        <option value="2">2 - @SharedLocalizer["Home_Easy"]</option>
                        <option value="3">3 - @SharedLocalizer["Home_Medium"]</option>
                        <option value="4">4 - @SharedLocalizer["Home_Hard"]</option>
                        <option value="5">5 - @SharedLocalizer["Home_Expert"]</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">@SharedLocalizer["Home_Players"]</label>
                    <select class="form-select form-select-sm" name="players">
                        <option value="">@SharedLocalizer["Home_Any"]</option>
                        @for (int i = 2; i <= 8; i++)
                        {
                            <option value="@i">@string.Format(SharedLocalizer["Home_PlayersCount"].Value, i)</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">@SharedLocalizer["Home_SortBy"]</label>
                    <select class="form-select form-select-sm" name="sort">
                        <option value="">@SharedLocalizer["Home_Recommended"]</option>
                        <option value="rating">@SharedLocalizer["Home_Rating"]</option>
                        <option value="reviews">@SharedLocalizer["Home_Reviews"]</option>
                        <option value="rooms_count">@SharedLocalizer["Home_Rooms"]</option>
                        <option value="name">@SharedLocalizer["Home_Name"]</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary btn-sm w-100">@SharedLocalizer["Home_Apply"]</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="container">
    @if (Model.TotalCount == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-search display-1 text-muted"></i>
            <h3 class="mt-3">@SharedLocalizer["Home_NoResults"]</h3>
            <p class="text-muted">@SharedLocalizer["Home_NoResultsMessage"]</p>
            <a href="/" class="btn btn-primary">@SharedLocalizer["Home_ClearFilters"]</a>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <p class="text-muted mb-0">
                @string.Format(SharedLocalizer["Home_Showing"].Value, (Model.Page - 1) * Model.PageSize + 1, Math.Min(Model.Page * Model.PageSize, Model.TotalCount), Model.TotalCount)
            </p>
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var venue in Model.Venues)
            {
                <div class="col">
                    <div class="card h-100 venue-card @(venue.IsPremium ? "border-warning" : "")">
                        @if (venue.IsPremium)
                        {
                            <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-2">@SharedLocalizer["Home_Featured"]</span>
                        }
                        <img src="@(venue.LocalImagePath ?? "/images/placeholder-venue.jpg")" class="card-img-top" alt="@venue.Name" style="height: 180px; object-fit: cover;">
                        <div class="card-body">
                            <h5 class="card-title">
                                <a href="/venue/@venue.Slug" class="text-decoration-none text-dark">@venue.Name</a>
                                @if (venue.IsVerified)
                                {
                                    <i class="bi bi-patch-check-fill text-primary" title="@SharedLocalizer["Home_Verified"]"></i>
                                }
                            </h5>
                            <p class="card-text text-muted small">
                                <i class="bi bi-geo-alt"></i> @venue.City, @venue.Country
                            </p>
                            <div class="d-flex align-items-center mb-2">
                                @if (venue.AverageRating.HasValue)
                                {
                                    <span class="badge bg-success me-2">
                                        <i class="bi bi-star-fill"></i> @venue.AverageRating.Value.ToString("F1")
                                    </span>
                                }
                                <small class="text-muted">@venue.TotalReviews @SharedLocalizer["Home_Reviews"].Value.ToLower()</small>
                            </div>
                            <p class="card-text">
                                <span class="badge bg-secondary">@venue.TotalRooms @SharedLocalizer["Home_Rooms"].Value.ToLower()</span>
                                @if (venue.MostPopularTheme != null)
                                {
                                    <span class="badge bg-info">@venue.MostPopularTheme</span>
                                }
                                @if (venue.LowestDifficulty.HasValue && venue.HighestDifficulty.HasValue)
                                {
                                    <span class="badge bg-light text-dark">
                                        @SharedLocalizer["Home_Difficulty"]: @venue.LowestDifficulty-@venue.HighestDifficulty
                                    </span>
                                }
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <a href="/venue/@venue.Slug" class="btn btn-outline-primary btn-sm w-100">
                                @SharedLocalizer["Home_ViewDetails"] <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" href="?page=@(Model.Page - 1)&query=@ViewBag.Query&city=@ViewBag.City&theme=@ViewBag.Theme">@SharedLocalizer["Common_Previous"]</a>
                    </li>
                    @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" href="?page=@i&query=@ViewBag.Query&city=@ViewBag.City&theme=@ViewBag.Theme">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                        <a class="page-link" href="?page=@(Model.Page + 1)&query=@ViewBag.Query&city=@ViewBag.City&theme=@ViewBag.Theme">@SharedLocalizer["Common_Next"]</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

@section Styles {
    <style>
        .venue-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
        }
    </style>
}
