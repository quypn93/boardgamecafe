@model ErrorViewModel
@{
    ViewData["Title"] = SharedLocalizer["Error_Title"].Value;
}

<div class="container mt-5">
    <div class="text-center">
        <h1 class="display-1 text-danger"><i class="bi bi-exclamation-triangle"></i></h1>
        <h2>@SharedLocalizer["Error_Message"]</h2>
        <p class="lead text-muted">@ViewBag.ErrorMessage</p>
        @if (Model?.ShowRequestId == true)
        {
            <p class="text-muted"><small>@SharedLocalizer["Error_RequestId"]: @Model.RequestId</small></p>
        }
        <a href="/" class="btn btn-primary mt-3">
            <i class="bi bi-house me-1"></i>@SharedLocalizer["Error_BackHome"]
        </a>
    </div>
</div>
