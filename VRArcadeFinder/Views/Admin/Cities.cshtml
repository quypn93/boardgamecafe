@model IEnumerable<City>
@{
    ViewData["Title"] = "Manage Cities";
}

<div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-building me-2"></i>Manage Crawl Cities</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCityModal">
            <i class="bi bi-plus-lg me-1"></i>Add City
        </button>
    </div>

    <!-- Cities Table -->
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>City</th>
                        <th>Country</th>
                        <th>Coordinates</th>
                        <th>Arcades Found</th>
                        <th>Last Crawled</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var city in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@city.Name</strong>
                                    @if (city.IsPriority)
                                    {
                                        <span class="badge bg-warning text-dark ms-1">Priority</span>
                                    }
                                </td>
                                <td>@city.Country</td>
                                <td>
                                    <small class="text-muted">@city.Latitude.ToString("0.0000"), @city.Longitude.ToString("0.0000")</small>
                                </td>
                                <td>@city.ArcadeCount</td>
                                <td>
                                    @if (city.LastCrawledAt.HasValue)
                                    {
                                        @city.LastCrawledAt.Value.ToString("dd/MM/yyyy HH:mm")
                                    }
                                    else
                                    {
                                        <span class="text-muted">Never</span>
                                    }
                                </td>
                                <td>
                                    @if (city.IsEnabled)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Disabled</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" onclick="crawlCity(@city.Id)" title="Crawl Now">
                                            <i class="bi bi-play-fill"></i>
                                        </button>
                                        <button class="btn btn-outline-secondary" onclick="editCity(@city.Id)" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        @if (city.IsEnabled)
                                        {
                                            <button class="btn btn-outline-warning" onclick="toggleCity(@city.Id, false)" title="Disable">
                                                <i class="bi bi-pause"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-success" onclick="toggleCity(@city.Id, true)" title="Enable">
                                                <i class="bi bi-check"></i>
                                            </button>
                                        }
                                        <button class="btn btn-outline-danger" onclick="deleteCity(@city.Id, '@city.Name')" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                <i class="bi bi-building display-6 d-block mb-2"></i>
                                No cities configured. Add cities to start crawling for VR arcades.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card mt-4">
        <div class="card-body">
            <h6>Quick Actions</h6>
            <button class="btn btn-outline-primary me-2" onclick="crawlAllCities()">
                <i class="bi bi-play-fill me-1"></i>Crawl All Active Cities
            </button>
            <button class="btn btn-outline-secondary me-2" onclick="importCities()">
                <i class="bi bi-upload me-1"></i>Import Cities (CSV)
            </button>
            <button class="btn btn-outline-info" onclick="exportCities()">
                <i class="bi bi-download me-1"></i>Export Cities
            </button>
        </div>
    </div>
</div>

<!-- Add City Modal -->
<div class="modal fade" id="addCityModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New City</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/admin/cities/add">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">City Name</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Country</label>
                        <select name="country" class="form-select" required>
                            <option value="">Select country...</option>
                            <option value="Vietnam">Vietnam</option>
                            <option value="United States">United States</option>
                            <option value="Japan">Japan</option>
                            <option value="South Korea">South Korea</option>
                            <option value="Singapore">Singapore</option>
                            <option value="Thailand">Thailand</option>
                            <option value="Malaysia">Malaysia</option>
                            <option value="Indonesia">Indonesia</option>
                            <option value="Philippines">Philippines</option>
                            <option value="Australia">Australia</option>
                            <option value="United Kingdom">United Kingdom</option>
                            <option value="Germany">Germany</option>
                            <option value="France">France</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Latitude</label>
                            <input type="number" name="latitude" class="form-control" step="0.0001" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Longitude</label>
                            <input type="number" name="longitude" class="form-control" step="0.0001" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Search Radius (meters)</label>
                        <input type="number" name="searchRadius" class="form-control" value="50000" min="1000" max="100000">
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" name="isPriority" id="isPriority">
                        <label class="form-check-label" for="isPriority">Priority City (crawl more frequently)</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add City</button>
                </div>
            </form>
        </div>
    </div>

@section Scripts {
    <script>
        function crawlCity(id) {
            if (confirm('Start crawling this city now?')) {
                fetch(`/admin/cities/crawl/${id}`, { method: 'POST' })
                    .then(response => {
                        if (response.ok) {
                            alert('Crawl started! Check the crawl management page for progress.');
                        } else {
                            alert('Failed to start crawl');
                        }
                    });
            }
        }

        function toggleCity(id, enable) {
            fetch(`/admin/cities/toggle/${id}?enable=${enable}`, { method: 'POST' })
                .then(response => {
                    if (response.ok) window.location.reload();
                    else alert('Failed to update city');
                });
        }

        function deleteCity(id, name) {
            if (confirm(`Are you sure you want to delete "${name}"?`)) {
                fetch(`/admin/cities/delete/${id}`, { method: 'POST' })
                    .then(response => {
                        if (response.ok) window.location.reload();
                        else alert('Failed to delete city');
                    });
            }
        }

        function crawlAllCities() {
            if (confirm('Start crawling all active cities? This may take a while.')) {
                fetch('/admin/cities/crawl-all', { method: 'POST' })
                    .then(response => {
                        if (response.ok) {
                            alert('Crawl started for all active cities!');
                        } else {
                            alert('Failed to start crawl');
                        }
                    });
            }
        }

        function editCity(id) {
            // TODO: Implement edit modal
            alert('Edit functionality coming soon');
        }

        function importCities() {
            // TODO: Implement CSV import
            alert('Import functionality coming soon');
        }

        function exportCities() {
            window.location.href = '/admin/cities/export';
        }
    </script>
}
