@model IEnumerable<User>
@{
    ViewData["Title"] = "Manage Users";
}

<h2><i class="bi bi-people me-2"></i>Manage Users</h2>
    <hr>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <input type="text" name="search" class="form-control" placeholder="Search by name or email..." value="@ViewBag.Search">
                </div>
                <div class="col-md-2">
                    <select name="role" class="form-select">
                        <option value="">All Roles</option>
                        @if (ViewBag.Role == "Admin") { <option value="Admin" selected>Admin</option> } else { <option value="Admin">Admin</option> }
                        @if (ViewBag.Role == "ArcadeOwner") { <option value="ArcadeOwner" selected>Arcade Owner</option> } else { <option value="ArcadeOwner">Arcade Owner</option> }
                        @if (ViewBag.Role == "User") { <option value="User" selected>User</option> } else { <option value="User">User</option> }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="status" class="form-select">
                        <option value="">All Status</option>
                        @if (ViewBag.Status == "active") { <option value="active" selected>Active</option> } else { <option value="active">Active</option> }
                        @if (ViewBag.Status == "locked") { <option value="locked" selected>Locked</option> } else { <option value="locked">Locked</option> }
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-outline-primary me-2">Filter</button>
                    <a href="/admin/users" class="btn btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Users Table -->
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Reviews</th>
                        <th>Joined</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(user.AvatarUrl))
                                        {
                                            <img src="@user.AvatarUrl" class="rounded-circle me-2" width="36" height="36" alt="">
                                        }
                                        else
                                        {
                                            <div class="bg-primary text-white rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                                                @user.DisplayName?.FirstOrDefault()
                                            </div>
                                        }
                                        <div>
                                            <strong>@user.DisplayName</strong>
                                            @if (user.EmailConfirmed)
                                            {
                                                <i class="bi bi-patch-check-fill text-primary ms-1" title="Email Verified"></i>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>@user.Email</td>
                                <td>
                                    @if (user.IsArcadeOwner)
                                    {
                                        <span class="badge bg-info">Arcade Owner</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">User</span>
                                    }
                                </td>
                                <td>@(user.Reviews?.Count ?? 0)</td>
                                <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.Now)
                                    {
                                        <span class="badge bg-danger">Locked</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/admin/users/edit/@user.Id" class="btn btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.Now)
                                        {
                                            <button class="btn btn-outline-success" onclick="unlockUser('@user.Id')" title="Unlock">
                                                <i class="bi bi-unlock"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-warning" onclick="lockUser('@user.Id')" title="Lock">
                                                <i class="bi bi-lock"></i>
                                            </button>
                                        }
                                        <button class="btn btn-outline-danger" onclick="deleteUser('@user.Id', '@user.Email')" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">
                                <i class="bi bi-people display-6 d-block mb-2"></i>
                                No users found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" href="?page=@i&search=@ViewBag.Search&role=@ViewBag.Role&status=@ViewBag.Status">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }

@section Scripts {
    <script>
        function lockUser(id) {
            if (confirm('Are you sure you want to lock this user?')) {
                fetch(`/admin/users/lock/${id}`, { method: 'POST' })
                    .then(response => {
                        if (response.ok) window.location.reload();
                        else alert('Failed to lock user');
                    });
            }
        }

        function unlockUser(id) {
            fetch(`/admin/users/unlock/${id}`, { method: 'POST' })
                .then(response => {
                    if (response.ok) window.location.reload();
                    else alert('Failed to unlock user');
                });
        }

        function deleteUser(id, email) {
            if (confirm(`Are you sure you want to delete user "${email}"? This action cannot be undone.`)) {
                fetch(`/admin/users/delete/${id}`, { method: 'POST' })
                    .then(response => {
                        if (response.ok) window.location.reload();
                        else alert('Failed to delete user');
                    });
            }
        }
    </script>
}
