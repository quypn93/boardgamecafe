@{
    ViewData["Title"] = "Crawl Management";
    var crawlHistory = ViewBag.CrawlHistory as IEnumerable<CrawlHistory>;
    var cities = ViewBag.Cities as IEnumerable<City>;
}

<h2><i class="bi bi-robot me-2"></i>Crawl Management</h2>
<hr>

<div class="row">
    <!-- Manual Crawl -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Manual Crawl</h5>
            </div>
            <div class="card-body">
                <form id="crawlForm">
                    <div class="mb-3">
                        <label class="form-label">Select City</label>
                        <select name="cityId" id="citySelect" class="form-select" required>
                            <option value="">Choose a city...</option>
                            @if (cities != null)
                            {
                                foreach (var city in cities)
                                {
                                    <option value="@city.CityId">@city.Name, @city.Country</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Search Radius (meters)</label>
                        <input type="number" name="radius" id="radiusInput" class="form-control" value="50000" min="1000" max="100000">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Search Keywords</label>
                        <input type="text" name="keywords" id="keywordsInput" class="form-control" value="VR arcade, virtual reality arcade, VR gaming center" placeholder="Comma-separated keywords">
                    </div>
                    <button type="submit" id="startCrawlBtn" class="btn btn-primary">
                        <i class="bi bi-play-fill me-1" id="btnIcon"></i>
                        <span id="btnText">Start Crawl</span>
                        <span id="btnSpinner" class="spinner-border spinner-border-sm ms-1 d-none" role="status"></span>
                    </button>
                </form>

                <!-- Crawl Progress Section -->
                <div id="crawlProgress" class="mt-4 d-none">
                    <hr>
                    <h6><i class="bi bi-hourglass-split me-2"></i>Crawl Progress</h6>
                    <div class="progress mb-3" style="height: 20px;">
                        <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%"></div>
                    </div>
                    <div class="bg-light p-3 rounded">
                        <div class="row">
                            <div class="col-6">
                                <small class="text-muted">Status:</small>
                                <div id="crawlStatus" class="fw-bold">-</div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">City:</small>
                                <div id="crawlCity" class="fw-bold">-</div>
                            </div>
                        </div>
                        <div class="row mt-2">
                            <div class="col-4">
                                <small class="text-muted">Found:</small>
                                <div id="arcadesFound" class="fw-bold text-primary">0</div>
                            </div>
                            <div class="col-4">
                                <small class="text-muted">Added:</small>
                                <div id="arcadesAdded" class="fw-bold text-success">0</div>
                            </div>
                            <div class="col-4">
                                <small class="text-muted">Updated:</small>
                                <div id="arcadesUpdated" class="fw-bold text-info">0</div>
                            </div>
                        </div>
                        <div id="errorSection" class="mt-2 d-none">
                            <small class="text-muted">Error:</small>
                            <div id="errorMessage" class="text-danger small"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Auto Crawl Settings -->
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Auto Crawl Settings</h5>
            </div>
            <div class="card-body">
                <form method="post" action="/admin/crawl/settings">
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" name="enabled" id="autoCrawlEnabled" @(ViewBag.AutoCrawlEnabled ? "checked" : "")>
                        <label class="form-check-label" for="autoCrawlEnabled">Enable Auto Crawl</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Crawl Interval (hours)</label>
                        <input type="number" name="intervalHours" class="form-control" value="@(ViewBag.CrawlInterval ?? 24)" min="1" max="168">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Max Results Per City</label>
                        <input type="number" name="maxResults" class="form-control" value="@(ViewBag.MaxResults ?? 50)" min="10" max="200">
                    </div>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save me-1"></i>Save Settings
                    </button>
                </form>
            </div>
        </div>

        <!-- Quick Stats -->
        <div class="card mt-4">
            <div class="card-header">
                <h5 class="mb-0">Crawl Statistics</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-4">
                        <h4 class="text-primary">@(ViewBag.TotalCrawls ?? 0)</h4>
                        <small class="text-muted">Total Crawls</small>
                    </div>
                    <div class="col-4">
                        <h4 class="text-success">@(ViewBag.TotalFound ?? 0)</h4>
                        <small class="text-muted">Arcades Found</small>
                    </div>
                    <div class="col-4">
                        <h4 class="text-info">@(ViewBag.CitiesCrawled ?? 0)</h4>
                        <small class="text-muted">Cities Crawled</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Danger Zone -->
        <div class="card mt-4 border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Danger Zone (Testing)</h5>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">These actions are destructive and cannot be undone. Use only for testing purposes.</p>
                <button type="button" class="btn btn-outline-danger me-2" data-bs-toggle="modal" data-bs-target="#clearDataModal">
                    <i class="bi bi-trash me-1"></i>Clear All Arcades
                </button>
                <button type="button" class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#clearHistoryModal">
                    <i class="bi bi-clock-history me-1"></i>Clear Crawl History
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Crawl History -->
<div class="card mt-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Crawl History</h5>
        <a href="/admin/crawl/history" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>City</th>
                    <th>Status</th>
                    <th>Found</th>
                    <th>New</th>
                    <th>Duration</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="crawlHistoryBody">
                @if (crawlHistory?.Any() == true)
                {
                    foreach (var crawl in crawlHistory.Take(10))
                    {
                        <tr>
                            <td>@crawl.StartedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@crawl.City?.Name</td>
                            <td>
                                @if (crawl.Status == "Completed")
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else if (crawl.Status == "Running" || crawl.Status == "InProgress")
                                {
                                    <span class="badge bg-primary">
                                        <span class="spinner-border spinner-border-sm me-1" style="width: 0.7rem; height: 0.7rem;"></span>
                                        Running
                                    </span>
                                }
                                else if (crawl.Status == "Failed")
                                {
                                    <span class="badge bg-danger">Failed</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@crawl.Status</span>
                                }
                            </td>
                            <td>@crawl.ArcadesFound</td>
                            <td>@crawl.ArcadesAdded</td>
                            <td>
                                @if (crawl.CompletedAt.HasValue)
                                {
                                    @((crawl.CompletedAt.Value - crawl.StartedAt).TotalMinutes.ToString("0.0"))@:min
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-secondary" onclick="viewLog(@crawl.CrawlHistoryId)" title="View Log">
                                    <i class="bi bi-file-text"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            No crawl history yet
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Log Modal -->
<div class="modal fade" id="logModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Crawl Log</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <pre id="logContent" class="bg-dark text-light p-3 rounded" style="max-height: 400px; overflow-y: auto;"></pre>
            </div>
        </div>
    </div>
</div>

<!-- Clear All Data Modal -->
<div class="modal fade" id="clearDataModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete All Arcades</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">This will permanently delete:</p>
                <ul>
                    <li><strong>All VR Arcades</strong> and their data</li>
                    <li>All associated <strong>reviews</strong></li>
                    <li>All associated <strong>photos</strong></li>
                    <li>All <strong>crawl history</strong></li>
                </ul>
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    <strong>This action cannot be undone!</strong>
                </div>
                <div class="mb-3">
                    <label class="form-label">Type <strong>DELETE</strong> to confirm:</label>
                    <input type="text" id="confirmDeleteInput" class="form-control" placeholder="Type DELETE">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn" disabled onclick="clearAllData()">
                    <i class="bi bi-trash me-1"></i>Delete All Data
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Clear History Modal -->
<div class="modal fade" id="clearHistoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title"><i class="bi bi-clock-history me-2"></i>Confirm Clear Crawl History</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>This will delete all crawl history records. Arcades will not be affected.</p>
                <p class="text-muted">This is useful for resetting crawl statistics without losing arcade data.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-warning" onclick="clearCrawlHistory()">
                    <i class="bi bi-trash me-1"></i>Clear History
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentCrawlId = null;
        let statusCheckInterval = null;

        // Form submission
        document.getElementById('crawlForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const cityId = document.getElementById('citySelect').value;
            const radius = document.getElementById('radiusInput').value;
            const keywords = document.getElementById('keywordsInput').value;

            if (!cityId) {
                alert('Please select a city');
                return;
            }

            // Disable button and show spinner
            const btn = document.getElementById('startCrawlBtn');
            const btnText = document.getElementById('btnText');
            const btnSpinner = document.getElementById('btnSpinner');
            const btnIcon = document.getElementById('btnIcon');

            btn.disabled = true;
            btnText.textContent = 'Starting...';
            btnSpinner.classList.remove('d-none');
            btnIcon.classList.add('d-none');

            // Show progress section
            document.getElementById('crawlProgress').classList.remove('d-none');
            document.getElementById('crawlStatus').innerHTML = '<span class="text-warning">Starting...</span>';

            try {
                const formData = new FormData();
                formData.append('cityId', cityId);
                formData.append('radius', radius);
                formData.append('keywords', keywords);

                const response = await fetch('/admin/crawl/start-ajax', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    currentCrawlId = result.crawlId;
                    btnText.textContent = 'Crawling...';
                    document.getElementById('crawlStatus').innerHTML = '<span class="text-primary">In Progress</span>';

                    // Start polling for status
                    startStatusPolling(result.crawlId);
                } else {
                    alert('Failed to start crawl: ' + result.error);
                    resetButton();
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred while starting the crawl');
                resetButton();
            }
        });

        function startStatusPolling(crawlId) {
            // Clear any existing interval
            if (statusCheckInterval) {
                clearInterval(statusCheckInterval);
            }

            // Poll every 3 seconds
            statusCheckInterval = setInterval(async () => {
                try {
                    const response = await fetch(`/admin/crawl/status/${crawlId}`);
                    const data = await response.json();

                    if (data.found) {
                        // Update progress display
                        document.getElementById('crawlCity').textContent = data.city || '-';
                        document.getElementById('arcadesFound').textContent = data.arcadesFound || 0;
                        document.getElementById('arcadesAdded').textContent = data.arcadesAdded || 0;
                        document.getElementById('arcadesUpdated').textContent = data.arcadesUpdated || 0;

                        if (data.errorMessage) {
                            document.getElementById('errorSection').classList.remove('d-none');
                            document.getElementById('errorMessage').textContent = data.errorMessage;
                        }

                        if (data.status === 'Completed') {
                            document.getElementById('crawlStatus').innerHTML = '<span class="text-success"><i class="bi bi-check-circle me-1"></i>Completed</span>';
                            document.getElementById('progressBar').classList.remove('progress-bar-animated');
                            document.getElementById('progressBar').classList.add('bg-success');
                            stopPollingAndReset();
                        } else if (data.status === 'Failed') {
                            document.getElementById('crawlStatus').innerHTML = '<span class="text-danger"><i class="bi bi-x-circle me-1"></i>Failed</span>';
                            document.getElementById('progressBar').classList.remove('progress-bar-animated');
                            document.getElementById('progressBar').classList.add('bg-danger');
                            stopPollingAndReset();
                        } else {
                            document.getElementById('crawlStatus').innerHTML = '<span class="text-primary"><span class="spinner-border spinner-border-sm me-1" style="width: 0.7rem; height: 0.7rem;"></span>In Progress</span>';
                        }
                    }
                } catch (error) {
                    console.error('Error checking status:', error);
                }
            }, 3000);
        }

        function stopPollingAndReset() {
            if (statusCheckInterval) {
                clearInterval(statusCheckInterval);
                statusCheckInterval = null;
            }

            // Re-enable button after a short delay
            setTimeout(() => {
                resetButton();
                // Optionally refresh the page to update the history
                // location.reload();
            }, 2000);
        }

        function resetButton() {
            const btn = document.getElementById('startCrawlBtn');
            const btnText = document.getElementById('btnText');
            const btnSpinner = document.getElementById('btnSpinner');
            const btnIcon = document.getElementById('btnIcon');

            btn.disabled = false;
            btnText.textContent = 'Start Crawl';
            btnSpinner.classList.add('d-none');
            btnIcon.classList.remove('d-none');
        }

        function viewLog(id) {
            fetch(`/admin/crawl/log/${id}`)
                .then(response => response.text())
                .then(log => {
                    document.getElementById('logContent').textContent = log;
                    new bootstrap.Modal(document.getElementById('logModal')).show();
                });
        }

        // Check if there's already a running crawl on page load
        document.addEventListener('DOMContentLoaded', async function() {
            try {
                const response = await fetch('/admin/crawl/latest-status');
                const data = await response.json();

                if (data.found && data.isRunning) {
                    // There's a running crawl, show progress
                    currentCrawlId = data.id;
                    document.getElementById('crawlProgress').classList.remove('d-none');
                    document.getElementById('crawlCity').textContent = data.city || '-';
                    document.getElementById('arcadesFound').textContent = data.arcadesFound || 0;
                    document.getElementById('arcadesAdded').textContent = data.arcadesAdded || 0;
                    document.getElementById('arcadesUpdated').textContent = data.arcadesUpdated || 0;
                    document.getElementById('crawlStatus').innerHTML = '<span class="text-primary"><span class="spinner-border spinner-border-sm me-1" style="width: 0.7rem; height: 0.7rem;"></span>In Progress</span>';

                    // Disable the button
                    const btn = document.getElementById('startCrawlBtn');
                    const btnText = document.getElementById('btnText');
                    const btnSpinner = document.getElementById('btnSpinner');
                    const btnIcon = document.getElementById('btnIcon');

                    btn.disabled = true;
                    btnText.textContent = 'Crawling...';
                    btnSpinner.classList.remove('d-none');
                    btnIcon.classList.add('d-none');

                    // Start polling
                    startStatusPolling(data.id);
                }
            } catch (error) {
                console.error('Error checking initial status:', error);
            }

            // Enable delete button only when "DELETE" is typed
            document.getElementById('confirmDeleteInput').addEventListener('input', function() {
                const btn = document.getElementById('confirmDeleteBtn');
                btn.disabled = this.value !== 'DELETE';
            });
        });

        // Clear all arcade data
        async function clearAllData() {
            const btn = document.getElementById('confirmDeleteBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Deleting...';

            try {
                const response = await fetch('/admin/crawl/clear-all-data', {
                    method: 'POST'
                });
                const result = await response.json();

                if (result.success) {
                    alert('All data has been cleared successfully!\n\n' +
                          'Arcades deleted: ' + result.arcadesDeleted + '\n' +
                          'Crawl history deleted: ' + result.historyDeleted);
                    location.reload();
                } else {
                    alert('Failed to clear data: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred while clearing data');
            }

            bootstrap.Modal.getInstance(document.getElementById('clearDataModal')).hide();
            document.getElementById('confirmDeleteInput').value = '';
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-trash me-1"></i>Delete All Data';
        }

        // Clear crawl history only
        async function clearCrawlHistory() {
            try {
                const response = await fetch('/admin/crawl/clear-history', {
                    method: 'POST'
                });
                const result = await response.json();

                if (result.success) {
                    alert('Crawl history cleared successfully!\n\nRecords deleted: ' + result.deleted);
                    location.reload();
                } else {
                    alert('Failed to clear history: ' + result.error);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred while clearing history');
            }

            bootstrap.Modal.getInstance(document.getElementById('clearHistoryModal')).hide();
        }
    </script>
}
