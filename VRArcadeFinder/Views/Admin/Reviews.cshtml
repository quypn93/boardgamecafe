@model IEnumerable<Review>
@{
    ViewData["Title"] = "Manage Reviews";
}

<h2><i class="bi bi-chat-quote me-2"></i>Manage Reviews</h2>
    <hr>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <select name="status" class="form-select">
                        <option value="">All Reviews</option>
                        @if (ViewBag.Status == "pending") { <option value="pending" selected>Pending Approval</option> } else { <option value="pending">Pending Approval</option> }
                        @if (ViewBag.Status == "approved") { <option value="approved" selected>Approved</option> } else { <option value="approved">Approved</option> }
                        @if (ViewBag.Status == "rejected") { <option value="rejected" selected>Rejected</option> } else { <option value="rejected">Rejected</option> }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="rating" class="form-select">
                        <option value="">All Ratings</option>
                        @if (ViewBag.Rating == "5") { <option value="5" selected>5 Stars</option> } else { <option value="5">5 Stars</option> }
                        @if (ViewBag.Rating == "4") { <option value="4" selected>4 Stars</option> } else { <option value="4">4 Stars</option> }
                        @if (ViewBag.Rating == "3") { <option value="3" selected>3 Stars</option> } else { <option value="3">3 Stars</option> }
                        @if (ViewBag.Rating == "2") { <option value="2" selected>2 Stars</option> } else { <option value="2">2 Stars</option> }
                        @if (ViewBag.Rating == "1") { <option value="1" selected>1 Star</option> } else { <option value="1">1 Star</option> }
                    </select>
                </div>
                <div class="col-md-3">
                    <input type="text" name="search" class="form-control" placeholder="Search content..." value="@ViewBag.Search">
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-outline-primary me-2">Filter</button>
                    <a href="/admin/reviews" class="btn btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Reviews List -->
    @if (Model.Any())
    {
        foreach (var review in Model)
        {
            <div class="card mb-3 @(review.IsApproved ? "" : "border-warning")">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h6 class="mb-1">
                                        <a href="/arcade/@review.Arcade?.Slug" target="_blank" class="text-decoration-none">@review.Arcade?.Name</a>
                                        @if (!review.IsApproved)
                                        {
                                            <span class="badge bg-warning text-dark ms-2">Pending</span>
                                        }
                                    </h6>
                                    <div class="text-warning mb-2">
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                        @for (int i = review.Rating; i < 5; i++)
                                        {
                                            <i class="bi bi-star"></i>
                                        }
                                    </div>
                                </div>
                                <small class="text-muted">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>

                            @if (!string.IsNullOrEmpty(review.Title))
                            {
                                <strong>@review.Title</strong>
                            }
                            <p class="mb-2">@review.Content</p>

                            <small class="text-muted">
                                <i class="bi bi-person me-1"></i>@review.User?.DisplayName (@review.User?.Email)
                            </small>
                        </div>
                        <div class="col-md-4 text-end">
                            @if (!review.IsApproved)
                            {
                                <button class="btn btn-success btn-sm me-1" onclick="approveReview(@review.Id)">
                                    <i class="bi bi-check-lg me-1"></i>Approve
                                </button>
                                <button class="btn btn-danger btn-sm" onclick="rejectReview(@review.Id)">
                                    <i class="bi bi-x-lg me-1"></i>Reject
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-outline-danger btn-sm" onclick="deleteReview(@review.Id)">
                                    <i class="bi bi-trash me-1"></i>Delete
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link" href="?page=@i&status=@ViewBag.Status&rating=@ViewBag.Rating">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-chat-square display-4 d-block mb-2"></i>
            <p>No reviews found</p>
        </div>
    }

@section Scripts {
    <script>
        function approveReview(id) {
            fetch(`/admin/reviews/approve/${id}`, { method: 'POST' })
                .then(response => {
                    if (response.ok) window.location.reload();
                    else alert('Failed to approve review');
                });
        }

        function rejectReview(id) {
            if (confirm('Are you sure you want to reject this review?')) {
                fetch(`/admin/reviews/reject/${id}`, { method: 'POST' })
                    .then(response => {
                        if (response.ok) window.location.reload();
                        else alert('Failed to reject review');
                    });
            }
        }

        function deleteReview(id) {
            if (confirm('Are you sure you want to delete this review?')) {
                fetch(`/admin/reviews/delete/${id}`, { method: 'POST' })
                    .then(response => {
                        if (response.ok) window.location.reload();
                        else alert('Failed to delete review');
                    });
            }
        }
    </script>
}
