@model MapViewModel
@{
    ViewData["Title"] = SharedLocalizer["Map_Title"].Value;
    var centerLat = Model.CenterLat ?? 10.8231;
    var centerLng = Model.CenterLng ?? 106.6297;
    var zoom = Model.Zoom ?? 12;
}

<div class="container-fluid p-0">
    <div class="row g-0">
        <!-- Sidebar -->
        <div class="col-md-4 col-lg-3 bg-light" style="height: calc(100vh - 56px); overflow-y: auto;">
            <div class="p-3">
                <h5><i class="bi bi-map me-2"></i>@SharedLocalizer["Map_FindArcades"]</h5>

                <!-- Search Form -->
                <form method="get" class="mb-3">
                    <div class="input-group mb-2">
                        <input type="text" name="city" class="form-control" placeholder="@SharedLocalizer["Map_EnterCity"]" value="@Model.City">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm w-100" onclick="findNearbyArcades()">
                        <i class="bi bi-geo-alt me-1"></i>@SharedLocalizer["Map_UseMyLocation"]
                    </button>
                </form>

                <!-- Filters -->
                <div class="accordion mb-3" id="filterAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#filtersCollapse">
                                <i class="bi bi-funnel me-2"></i>@SharedLocalizer["Map_Filters"]
                            </button>
                        </h2>
                        <div id="filtersCollapse" class="accordion-collapse collapse" data-bs-parent="#filterAccordion">
                            <div class="accordion-body">
                                <div class="mb-2">
                                    <label class="form-label small">@SharedLocalizer["Map_VRPlatform"]</label>
                                    <select name="platform" class="form-select form-select-sm">
                                        <option value="">@SharedLocalizer["Map_AllPlatforms"]</option>
                                        <option value="Quest">Meta Quest</option>
                                        <option value="PCVR">PC VR</option>
                                        <option value="PSVR">PlayStation VR</option>
                                    </select>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" name="hasPartyRooms" id="hasPartyRooms">
                                    <label class="form-check-label small" for="hasPartyRooms">@SharedLocalizer["Map_HasPartyRooms"]</label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" name="hasMultiplayer" id="hasMultiplayer">
                                    <label class="form-check-label small" for="hasMultiplayer">@SharedLocalizer["Map_MultiplayerArea"]</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Results List -->
                <div id="arcadeList">
                    @if (Model.Arcades?.Any() == true)
                    {
                        <p class="text-muted small mb-2">@Model.Arcades.Count() @SharedLocalizer["Map_ArcadesFound"]</p>
                        @foreach (var arcade in Model.Arcades)
                        {
                            <div class="card mb-2 arcade-list-item" data-lat="@arcade.Latitude" data-lng="@arcade.Longitude" onclick="focusArcade(@arcade.Id)">
                                <div class="card-body p-2">
                                    <h6 class="mb-1">
                                        <a href="/arcade/@arcade.Slug" class="text-decoration-none">@arcade.Name</a>
                                        @if (arcade.IsPremium)
                                        {
                                            <i class="bi bi-patch-check-fill text-primary ms-1" title="@SharedLocalizer["Arcade_Verified"]"></i>
                                        }
                                    </h6>
                                    <p class="text-muted small mb-1">
                                        <i class="bi bi-geo-alt"></i> @arcade.Address
                                    </p>
                                    @if (arcade.Rating > 0)
                                    {
                                        <span class="text-warning small">
                                            @for (int i = 0; i < (int)arcade.Rating; i++)
                                            {
                                                <i class="bi bi-star-fill"></i>
                                            }
                                        </span>
                                        <span class="text-muted small">(@arcade.ReviewCount)</span>
                                    }
                                    @if (arcade.Distance.HasValue)
                                    {
                                        <span class="badge bg-secondary ms-2">@((arcade.Distance.Value / 1000).ToString("0.0")) km</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-search display-4"></i>
                            <p class="mt-2">@SharedLocalizer["Map_SearchForArcades"]</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Map -->
        <div class="col-md-8 col-lg-9">
            <div id="map" style="height: calc(100vh - 56px); width: 100%;"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://maps.googleapis.com/maps/api/js?key=@ViewBag.GoogleMapsApiKey&callback=initMap" async defer></script>
    <script>
        let map;
        let markers = [];
        let infoWindow;
        const viewDetailsText = '@SharedLocalizer["Map_ViewDetails"]';
        const locationErrorText = '@SharedLocalizer["Map_UnableToGetLocation"]';

        // Arcade data from server
        const arcadeData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Arcades ?? new List<MapArcadeDto>()));

        function initMap() {
            const defaultCenter = { lat: @centerLat, lng: @centerLng };

            map = new google.maps.Map(document.getElementById('map'), {
                center: defaultCenter,
                zoom: @zoom,
                styles: [
                    {
                        featureType: "poi",
                        elementType: "labels",
                        stylers: [{ visibility: "off" }]
                    }
                ]
            });

            infoWindow = new google.maps.InfoWindow();

            // Add markers for arcades
            arcadeData.forEach(arcade => {
                addMarker({
                    id: arcade.id,
                    lat: arcade.latitude,
                    lng: arcade.longitude,
                    name: arcade.name,
                    address: arcade.address,
                    slug: arcade.slug,
                    rating: arcade.rating,
                    isPremium: arcade.isPremium
                });
            });

            // Fit bounds if we have markers
            if (markers.length > 0) {
                const bounds = new google.maps.LatLngBounds();
                markers.forEach(m => bounds.extend(m.getPosition()));
                map.fitBounds(bounds);
            }
        }

        function addMarker(arcade) {
            const marker = new google.maps.Marker({
                position: { lat: arcade.lat, lng: arcade.lng },
                map: map,
                title: arcade.name,
                icon: arcade.isPremium ? {
                    url: 'https://maps.google.com/mapfiles/ms/icons/purple-dot.png'
                } : null
            });

            marker.arcadeId = arcade.id;

            marker.addListener('click', () => {
                const content = `
                    <div style="max-width: 200px;">
                        <h6>${arcade.name}</h6>
                        <p class="small text-muted mb-1">${arcade.address || ''}</p>
                        ${arcade.rating > 0 ? `<span class="text-warning">★</span> ${arcade.rating.toFixed(1)}` : ''}
                        <br>
                        <a href="/arcade/${arcade.slug}" class="btn btn-sm btn-primary mt-2">${viewDetailsText}</a>
                    </div>
                `;
                infoWindow.setContent(content);
                infoWindow.open(map, marker);
            });

            markers.push(marker);
        }

        function focusArcade(id) {
            const marker = markers.find(m => m.arcadeId === id);
            if (marker) {
                map.setCenter(marker.getPosition());
                map.setZoom(15);
                google.maps.event.trigger(marker, 'click');
            }
        }

        function findNearbyArcades() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    position => {
                        window.location.href = `/map?lat=${position.coords.latitude}&lng=${position.coords.longitude}&radius=50000`;
                    },
                    error => {
                        alert(locationErrorText);
                    }
                );
            }
        }
    </script>
}
