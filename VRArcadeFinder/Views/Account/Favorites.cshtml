@model IEnumerable<Arcade>
@{
    ViewData["Title"] = SharedLocalizer["Favorites_Title"].Value;
}

<div class="container mt-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
            <div class="card">
                <div class="list-group list-group-flush">
                    <a href="/account/profile" class="list-group-item list-group-item-action">
                        <i class="bi bi-person me-2"></i>@SharedLocalizer["Nav_Profile"]
                    </a>
                    <a href="/account/favorites" class="list-group-item list-group-item-action active">
                        <i class="bi bi-heart me-2"></i>@SharedLocalizer["Profile_Favorites"]
                    </a>
                    <a href="/account/reviews" class="list-group-item list-group-item-action">
                        <i class="bi bi-chat-quote me-2"></i>@SharedLocalizer["Profile_MyReviews"]
                    </a>
                    <a href="/account/settings" class="list-group-item list-group-item-action">
                        <i class="bi bi-gear me-2"></i>@SharedLocalizer["Profile_Settings"]
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <h3><i class="bi bi-heart-fill text-danger me-2"></i>@SharedLocalizer["Favorites_Title"]</h3>
            <hr>

            @if (Model.Any())
            {
                <div class="row">
                    @foreach (var arcade in Model)
                    {
                        <div class="col-md-6 mb-4">
                            <div class="card h-100 arcade-card">
                                <div class="position-relative">
                                    @if (!string.IsNullOrEmpty(arcade.CoverImageUrl))
                                    {
                                        <img src="@arcade.CoverImageUrl" class="card-img-top" alt="@arcade.Name" style="height: 150px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 150px;">
                                            <i class="bi bi-shop text-white" style="font-size: 3rem;"></i>
                                        </div>
                                    }
                                    <button class="btn btn-sm btn-danger position-absolute top-0 end-0 m-2" onclick="removeFavorite(@arcade.Id)" title="@SharedLocalizer["Favorites_RemoveFromFavorites"]">
                                        <i class="bi bi-heart-fill"></i>
                                    </button>
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title">
                                        <a href="/arcade/@arcade.Slug" class="text-decoration-none">@arcade.Name</a>
                                        @if (arcade.IsVerified)
                                        {
                                            <i class="bi bi-patch-check-fill text-primary ms-1"></i>
                                        }
                                    </h5>
                                    <p class="text-muted small mb-2">
                                        <i class="bi bi-geo-alt me-1"></i>@arcade.City, @arcade.Country
                                    </p>
                                    @if (arcade.AverageRating > 0)
                                    {
                                        <div class="mb-2">
                                            <span class="text-warning">
                                                @for (int i = 0; i < (int)arcade.AverageRating; i++)
                                                {
                                                    <i class="bi bi-star-fill"></i>
                                                }
                                            </span>
                                            <span class="text-muted small">(@arcade.TotalReviews @SharedLocalizer["Arcade_Reviews"])</span>
                                        </div>
                                    }
                                    <div class="d-flex flex-wrap gap-1">
                                        @if (!string.IsNullOrEmpty(arcade.VRPlatforms))
                                        {
                                            foreach (var platform in arcade.VRPlatforms.Split(',').Take(3))
                                            {
                                                <span class="badge bg-light text-dark">@platform.Trim()</span>
                                            }
                                        }
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent">
                                    <a href="/arcade/@arcade.Slug" class="btn btn-primary btn-sm w-100">@SharedLocalizer["Favorites_ViewDetails"]</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-heart display-1 text-muted"></i>
                    <h4 class="mt-3">@SharedLocalizer["Favorites_NoFavorites"]</h4>
                    <p class="text-muted">@SharedLocalizer["Favorites_NoFavoritesMessage"]</p>
                    <a href="/" class="btn btn-primary">@SharedLocalizer["Favorites_BrowseArcades"]</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function removeFavorite(arcadeId) {
            if (confirm('@SharedLocalizer["Favorites_ConfirmRemove"]')) {
                fetch(`/api/favorites/${arcadeId}`, { method: 'DELETE' })
                    .then(response => {
                        if (response.ok) window.location.reload();
                        else alert('Failed to remove favorite');
                    });
            }
        }
    </script>
}
