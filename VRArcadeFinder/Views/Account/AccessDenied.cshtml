@{
    ViewData["Title"] = SharedLocalizer["AccessDenied_Title"].Value;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="mb-4">
                <i class="bi bi-shield-exclamation text-danger" style="font-size: 5rem;"></i>
            </div>
            <h1 class="display-5">@SharedLocalizer["AccessDenied_Title"]</h1>
            <p class="lead text-muted">@SharedLocalizer["AccessDenied_Message"]</p>
            <p class="text-muted">
                @SharedLocalizer["AccessDenied_ContactAdmin"]
            </p>
            <div class="mt-4">
                <a href="/" class="btn btn-primary me-2">
                    <i class="bi bi-house me-1"></i>@SharedLocalizer["AccessDenied_GoHome"]
                </a>
                <a href="/account/login" class="btn btn-outline-secondary">
                    <i class="bi bi-box-arrow-in-right me-1"></i>@SharedLocalizer["Account_Login"]
                </a>
            </div>
        </div>
    </div>
</div>
