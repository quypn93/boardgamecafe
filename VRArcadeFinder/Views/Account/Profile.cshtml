@model User
@{
    ViewData["Title"] = SharedLocalizer["Profile_Title"].Value;
}

<div class="container mt-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
            <div class="card">
                <div class="card-body text-center">
                    @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                    {
                        <img src="@Model.AvatarUrl" class="rounded-circle mb-3" width="100" height="100" alt="Avatar">
                    }
                    else
                    {
                        <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 100px; height: 100px; font-size: 2.5rem;">
                            @Model.DisplayName?.FirstOrDefault()
                        </div>
                    }
                    <h5>@Model.DisplayName</h5>
                    <p class="text-muted small">@Model.Email</p>
                    <p class="text-muted small">
                        <i class="bi bi-calendar me-1"></i>@SharedLocalizer["Profile_MemberSince"] @Model.CreatedAt.ToString("MMM yyyy")
                    </p>
                </div>
                <div class="list-group list-group-flush">
                    <a href="/account/profile" class="list-group-item list-group-item-action active">
                        <i class="bi bi-person me-2"></i>@SharedLocalizer["Nav_Profile"]
                    </a>
                    <a href="/account/favorites" class="list-group-item list-group-item-action">
                        <i class="bi bi-heart me-2"></i>@SharedLocalizer["Profile_Favorites"]
                    </a>
                    <a href="/account/reviews" class="list-group-item list-group-item-action">
                        <i class="bi bi-chat-quote me-2"></i>@SharedLocalizer["Profile_MyReviews"]
                    </a>
                    @if (Model.IsArcadeOwner)
                    {
                        <a href="/account/my-arcades" class="list-group-item list-group-item-action">
                            <i class="bi bi-shop me-2"></i>@SharedLocalizer["Profile_MyArcades"]
                        </a>
                    }
                    <a href="/account/settings" class="list-group-item list-group-item-action">
                        <i class="bi bi-gear me-2"></i>@SharedLocalizer["Profile_Settings"]
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-person me-2"></i>@SharedLocalizer["Profile_EditProfile"]</h5>
                </div>
                <div class="card-body">
                    <form method="post" enctype="multipart/form-data">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">@SharedLocalizer["Profile_DisplayName"]</label>
                                <input type="text" name="displayName" class="form-control" value="@Model.DisplayName" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">@SharedLocalizer["Account_Email"]</label>
                                <input type="email" class="form-control" value="@Model.Email" disabled>
                                <small class="text-muted">@SharedLocalizer["Profile_ContactSupport"]</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@SharedLocalizer["Profile_Bio"]</label>
                            <textarea name="bio" class="form-control" rows="3" placeholder="@SharedLocalizer["Profile_BioPlaceholder"]">@Model.Bio</textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@SharedLocalizer["Profile_Avatar"]</label>
                            <input type="file" name="avatar" class="form-control" accept="image/*">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@SharedLocalizer["Profile_FavoriteVRPlatforms"]</label>
                            <div class="row">
                                @{
                                    var platforms = new[] { "Meta Quest", "PC VR (SteamVR)", "PlayStation VR", "Valve Index", "HTC Vive", "Pico" };
                                    var favorites = Model.FavoriteVRPlatforms?.Split(',') ?? Array.Empty<string>();
                                }
                                @foreach (var platform in platforms)
                                {
                                    <div class="col-md-4 mb-2">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="platforms" value="@platform"
                                                   id="platform_@platform.Replace(" ", "_")"
                                                   @(favorites.Contains(platform) ? "checked" : "")>
                                            <label class="form-check-label" for="platform_@platform.Replace(" ", "_")">@platform</label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">@SharedLocalizer["Profile_PreferredLanguage"]</label>
                            <select name="preferredLanguage" class="form-select">
                                @if (Model.PreferredLanguage == "en") { <option value="en" selected>English</option> } else { <option value="en">English</option> }
                                @if (Model.PreferredLanguage == "vi") { <option value="vi" selected>Tiếng Việt</option> } else { <option value="vi">Tiếng Việt</option> }
                            </select>
                        </div>

                        <hr>

                        <h6>@SharedLocalizer["Profile_Notifications"]</h6>
                        <div class="form-check mb-2">
                            @if (Model.EmailNotifications)
                            {
                                <input class="form-check-input" type="checkbox" name="emailNotifications" id="emailNotifications" checked>
                            }
                            else
                            {
                                <input class="form-check-input" type="checkbox" name="emailNotifications" id="emailNotifications">
                            }
                            <label class="form-check-label" for="emailNotifications">
                                @SharedLocalizer["Profile_EmailNotifications"]
                            </label>
                        </div>
                        <div class="form-check mb-3">
                            @if (Model.EventNotifications)
                            {
                                <input class="form-check-input" type="checkbox" name="eventNotifications" id="eventNotifications" checked>
                            }
                            else
                            {
                                <input class="form-check-input" type="checkbox" name="eventNotifications" id="eventNotifications">
                            }
                            <label class="form-check-label" for="eventNotifications">
                                @SharedLocalizer["Profile_EventNotifications"]
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-1"></i>@SharedLocalizer["Profile_SaveChanges"]
                        </button>
                    </form>
                </div>
            </div>

            <!-- Change Password -->
            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>@SharedLocalizer["Profile_ChangePassword"]</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="ChangePassword">
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">@SharedLocalizer["Profile_CurrentPassword"]</label>
                                <input type="password" name="currentPassword" class="form-control" required>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">@SharedLocalizer["Profile_NewPassword"]</label>
                                <input type="password" name="newPassword" class="form-control" required>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">@SharedLocalizer["Profile_ConfirmNewPassword"]</label>
                                <input type="password" name="confirmPassword" class="form-control" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-outline-primary">@SharedLocalizer["Profile_ChangePassword"]</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
