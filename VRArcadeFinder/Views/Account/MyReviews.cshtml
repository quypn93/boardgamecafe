@model IEnumerable<Review>
@{
    ViewData["Title"] = "My Reviews";
}

<div class="container mt-4">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3">
            <div class="card">
                <div class="list-group list-group-flush">
                    <a href="/account/profile" class="list-group-item list-group-item-action">
                        <i class="bi bi-person me-2"></i>Profile
                    </a>
                    <a href="/account/favorites" class="list-group-item list-group-item-action">
                        <i class="bi bi-heart me-2"></i>Favorites
                    </a>
                    <a href="/account/reviews" class="list-group-item list-group-item-action active">
                        <i class="bi bi-chat-quote me-2"></i>My Reviews
                    </a>
                    <a href="/account/settings" class="list-group-item list-group-item-action">
                        <i class="bi bi-gear me-2"></i>Settings
                    </a>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-9">
            <h3><i class="bi bi-chat-quote me-2"></i>My Reviews</h3>
            <hr>

            @if (Model.Any())
            {
                foreach (var review in Model)
                {
                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <h5 class="mb-1">
                                        <a href="/arcade/@review.Arcade?.Slug" class="text-decoration-none">@review.Arcade?.Name</a>
                                    </h5>
                                    <div class="text-warning mb-2">
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <i class="bi bi-star-fill"></i>
                                        }
                                        @for (int i = review.Rating; i < 5; i++)
                                        {
                                            <i class="bi bi-star"></i>
                                        }
                                    </div>
                                </div>
                                <div class="text-end">
                                    <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                                    <div>
                                        @if (review.IsApproved)
                                        {
                                            <span class="badge bg-success">Published</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(review.Title))
                            {
                                <strong>@review.Title</strong>
                            }
                            <p class="mb-2">@review.Content</p>

                            @if (review.HelpfulCount > 0)
                            {
                                <small class="text-muted">
                                    <i class="bi bi-hand-thumbs-up me-1"></i>@review.HelpfulCount people found this helpful
                                </small>
                            }

                            <div class="mt-3">
                                <button class="btn btn-sm btn-outline-primary me-1" onclick="editReview(@review.Id)">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteReview(@review.Id)">
                                    <i class="bi bi-trash me-1"></i>Delete
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-chat-square display-1 text-muted"></i>
                    <h4 class="mt-3">No reviews yet</h4>
                    <p class="text-muted">Visit a VR arcade and share your experience!</p>
                    <a href="/" class="btn btn-primary">Find Arcades</a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Edit Review Modal -->
<div class="modal fade" id="editReviewModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Review</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editReviewForm" method="post">
                <div class="modal-body">
                    <input type="hidden" name="reviewId" id="editReviewId">
                    <div class="mb-3">
                        <label class="form-label">Rating</label>
                        <div id="editRatingStars" class="rating-input">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi bi-star fs-4 text-warning" data-rating="@i" style="cursor: pointer;"></i>
                            }
                        </div>
                        <input type="hidden" name="rating" id="editRating">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" name="title" id="editTitle" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Your Review</label>
                        <textarea name="content" id="editContent" class="form-control" rows="4" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function editReview(id) {
            fetch(`/api/reviews/${id}`)
                .then(response => response.json())
                .then(review => {
                    document.getElementById('editReviewId').value = review.id;
                    document.getElementById('editTitle').value = review.title || '';
                    document.getElementById('editContent').value = review.content;
                    document.getElementById('editRating').value = review.rating;
                    updateStars(review.rating);
                    new bootstrap.Modal(document.getElementById('editReviewModal')).show();
                });
        }

        function updateStars(rating) {
            document.querySelectorAll('#editRatingStars i').forEach((star, index) => {
                star.classList.toggle('bi-star-fill', index < rating);
                star.classList.toggle('bi-star', index >= rating);
            });
        }

        document.querySelectorAll('#editRatingStars i').forEach(star => {
            star.addEventListener('click', function() {
                const rating = parseInt(this.dataset.rating);
                document.getElementById('editRating').value = rating;
                updateStars(rating);
            });
        });

        function deleteReview(id) {
            if (confirm('Are you sure you want to delete this review?')) {
                fetch(`/api/reviews/${id}`, { method: 'DELETE' })
                    .then(response => {
                        if (response.ok) window.location.reload();
                        else alert('Failed to delete review');
                    });
            }
        }

        document.getElementById('editReviewForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            fetch(`/api/reviews/${formData.get('reviewId')}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    rating: parseInt(formData.get('rating')),
                    title: formData.get('title'),
                    content: formData.get('content')
                })
            }).then(response => {
                if (response.ok) window.location.reload();
                else alert('Failed to update review');
            });
        });
    </script>
}
