@model IEnumerable<VRGame>
@{
    ViewData["Title"] = "VR Games";
}

<div class="container mt-4">
    <h1><i class="bi bi-controller me-2"></i>VR Games</h1>
    <p class="lead text-muted">Browse our catalog of VR games available at arcades</p>
    <hr>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="search" class="form-control" placeholder="Search games..." value="@ViewBag.Search">
                </div>
                <div class="col-md-2">
                    <select name="platform" class="form-select">
                        <option value="">All Platforms</option>
                        @if (ViewBag.Platform == "Quest") { <option value="Quest" selected>Meta Quest</option> } else { <option value="Quest">Meta Quest</option> }
                        @if (ViewBag.Platform == "PCVR") { <option value="PCVR" selected>PC VR</option> } else { <option value="PCVR">PC VR</option> }
                        @if (ViewBag.Platform == "PSVR") { <option value="PSVR" selected>PlayStation VR</option> } else { <option value="PSVR">PlayStation VR</option> }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="genre" class="form-select">
                        <option value="">All Genres</option>
                        @if (ViewBag.Genre == "Action") { <option value="Action" selected>Action</option> } else { <option value="Action">Action</option> }
                        @if (ViewBag.Genre == "Adventure") { <option value="Adventure" selected>Adventure</option> } else { <option value="Adventure">Adventure</option> }
                        @if (ViewBag.Genre == "Horror") { <option value="Horror" selected>Horror</option> } else { <option value="Horror">Horror</option> }
                        @if (ViewBag.Genre == "Puzzle") { <option value="Puzzle" selected>Puzzle</option> } else { <option value="Puzzle">Puzzle</option> }
                        @if (ViewBag.Genre == "Sports") { <option value="Sports" selected>Sports</option> } else { <option value="Sports">Sports</option> }
                        @if (ViewBag.Genre == "Simulation") { <option value="Simulation" selected>Simulation</option> } else { <option value="Simulation">Simulation</option> }
                        @if (ViewBag.Genre == "Social") { <option value="Social" selected>Social</option> } else { <option value="Social">Social</option> }
                        @if (ViewBag.Genre == "Rhythm") { <option value="Rhythm" selected>Rhythm</option> } else { <option value="Rhythm">Rhythm</option> }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="intensity" class="form-select">
                        <option value="">All Intensities</option>
                        @if (ViewBag.Intensity == "Low") { <option value="Low" selected>Low (Comfortable)</option> } else { <option value="Low">Low (Comfortable)</option> }
                        @if (ViewBag.Intensity == "Medium") { <option value="Medium" selected>Medium (Moderate)</option> } else { <option value="Medium">Medium (Moderate)</option> }
                        @if (ViewBag.Intensity == "High") { <option value="High" selected>High (Intense)</option> } else { <option value="High">High (Intense)</option> }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary me-2">Filter</button>
                    <a href="/games" class="btn btn-outline-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Games Grid -->
    @if (Model.Any())
    {
        <div class="row">
            @foreach (var game in Model)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 game-card">
                        @if (!string.IsNullOrEmpty(game.ImageUrl))
                        {
                            <img src="@game.ImageUrl" class="card-img-top" alt="@game.Name" style="height: 180px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 180px;">
                                <i class="bi bi-controller text-white" style="font-size: 4rem;"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@game.Name</h5>
                            <div class="mb-2">
                                <span class="badge bg-primary">@game.VRPlatform</span>
                                <span class="badge bg-secondary">@game.Genre</span>
                                @if (game.IsMultiplayer)
                                {
                                    <span class="badge bg-success">Multiplayer</span>
                                }
                                @if (game.IsCoOp)
                                {
                                    <span class="badge bg-info">Co-op</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(game.IntensityLevel))
                            {
                                <p class="small mb-2">
                                    <strong>Intensity:</strong>
                                    @if (game.IntensityLevel == "Low")
                                    {
                                        <span class="text-success">Low (Comfortable)</span>
                                    }
                                    else if (game.IntensityLevel == "Medium")
                                    {
                                        <span class="text-warning">Medium</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">High (Intense)</span>
                                    }
                                </p>
                            }
                            <p class="card-text small text-muted">
                                @(game.Description?.Length > 100 ? game.Description.Substring(0, 100) + "..." : game.Description)
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    <i class="bi bi-shop me-1"></i>@(game.ArcadeGames?.Count ?? 0) arcades
                                </small>
                                <a href="/games/@game.Slug" class="btn btn-sm btn-outline-primary">Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link" href="?page=@i&search=@ViewBag.Search&platform=@ViewBag.Platform&genre=@ViewBag.Genre&intensity=@ViewBag.Intensity">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-controller display-1 text-muted"></i>
            <h4 class="mt-3">No games found</h4>
            <p class="text-muted">Try adjusting your filters or search terms.</p>
        </div>
    }
</div>

<style>
    .game-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .game-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }
    .game-card .card-img-top {
        transition: transform 0.3s ease;
    }
    .game-card:hover .card-img-top {
        transform: scale(1.05);
    }
    .game-card {
        overflow: hidden;
    }
</style>
