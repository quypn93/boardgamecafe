@{
    ViewData["Title"] = "About VR Arcade Finder";
}

<div class="container mt-4">
    <!-- Hero -->
    <div class="text-center mb-5">
        <h1><i class="bi bi-info-circle me-2"></i>About VR Arcade Finder</h1>
        <p class="lead text-muted">Your gateway to immersive virtual reality experiences</p>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- Mission -->
            <div class="card mb-4">
                <div class="card-body">
                    <h3><i class="bi bi-rocket-takeoff text-primary me-2"></i>Our Mission</h3>
                    <p>
                        VR Arcade Finder is dedicated to connecting VR enthusiasts with the best virtual reality arcades
                        around the world. We believe that everyone should have access to premium VR experiences, whether
                        you're a first-time user curious about virtual reality or a seasoned gamer looking for the latest
                        experiences.
                    </p>
                    <p class="mb-0">
                        Our platform makes it easy to discover, compare, and choose VR arcades based on location,
                        available games, equipment, and user reviews.
                    </p>
                </div>
            </div>

            <!-- Features -->
            <div class="card mb-4">
                <div class="card-body">
                    <h3><i class="bi bi-stars text-primary me-2"></i>What We Offer</h3>
                    <div class="row mt-3">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex">
                                <i class="bi bi-geo-alt-fill text-primary fs-4 me-3"></i>
                                <div>
                                    <h6>Location-Based Search</h6>
                                    <p class="text-muted small mb-0">Find VR arcades near you with our powerful search and map features.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex">
                                <i class="bi bi-controller text-primary fs-4 me-3"></i>
                                <div>
                                    <h6>Game Catalog</h6>
                                    <p class="text-muted small mb-0">Browse thousands of VR games and find arcades that have them.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex">
                                <i class="bi bi-star-fill text-primary fs-4 me-3"></i>
                                <div>
                                    <h6>User Reviews</h6>
                                    <p class="text-muted small mb-0">Read honest reviews from real VR arcade visitors.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex">
                                <i class="bi bi-calendar-event text-primary fs-4 me-3"></i>
                                <div>
                                    <h6>Events & Tournaments</h6>
                                    <p class="text-muted small mb-0">Discover VR gaming events and competitions near you.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- For Arcade Owners -->
            <div class="card mb-4">
                <div class="card-body">
                    <h3><i class="bi bi-shop text-primary me-2"></i>For Arcade Owners</h3>
                    <p>
                        Are you a VR arcade owner? Join our platform to increase your visibility and reach thousands
                        of potential customers actively searching for VR experiences.
                    </p>
                    <ul>
                        <li>Create a detailed listing with photos and game inventory</li>
                        <li>Respond to customer reviews and build your reputation</li>
                        <li>Post events and special promotions</li>
                        <li>Access analytics to understand your audience</li>
                        <li>Featured placement options for maximum exposure</li>
                    </ul>
                    <a href="/listing/pricing" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-1"></i>List Your Arcade
                    </a>
                </div>
            </div>

            <!-- Contact -->
            <div class="card">
                <div class="card-body">
                    <h3><i class="bi bi-envelope text-primary me-2"></i>Contact Us</h3>
                    <p>Have questions, feedback, or partnership inquiries? We'd love to hear from you!</p>
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Email:</strong></p>
                            <p><a href="mailto:hello@vrarcadefinder.com">hello@vrarcadefinder.com</a></p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Follow Us:</strong></p>
                            <a href="#" class="btn btn-outline-dark btn-sm me-1"><i class="bi bi-twitter"></i></a>
                            <a href="#" class="btn btn-outline-dark btn-sm me-1"><i class="bi bi-facebook"></i></a>
                            <a href="#" class="btn btn-outline-dark btn-sm me-1"><i class="bi bi-instagram"></i></a>
                            <a href="#" class="btn btn-outline-dark btn-sm"><i class="bi bi-youtube"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
