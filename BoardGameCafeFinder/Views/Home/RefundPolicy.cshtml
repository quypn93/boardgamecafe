@{
    ViewData["Title"] = "Refund Policy";
    ViewData["MetaDescription"] = "Read our refund policy for Board Game Cafe Finder premium listing subscriptions.";
    Layout = "_UserLayout";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <h1 class="mb-4">Refund Policy</h1>
            <p class="text-muted">Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">1. Overview</h2>
                    <p>
                        This Refund Policy applies to all paid services offered through Board Game Cafe Finder ("the Service"),
                        including premium listing subscriptions (Basic, Premium, and Featured plans). We want you to be satisfied
                        with your purchase, and we strive to resolve any issues promptly.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">2. Subscription Plans</h2>
                    <p>
                        Board Game Cafe Finder offers month-to-month subscription plans for cafe owners who wish to enhance
                        their listing visibility. All subscriptions are billed on a recurring monthly basis unless cancelled.
                    </p>
                    <ul>
                        <li><strong>Basic Plan</strong> – Basic listing with contact information, business hours, and map location</li>
                        <li><strong>Premium Plan</strong> – Includes photo gallery, event listings, and priority search placement</li>
                        <li><strong>Featured Plan</strong> – Includes homepage placement, game inventory manager, analytics dashboard, and unlimited photos</li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">3. Cancellation Policy</h2>
                    <p>
                        You may cancel your subscription at any time. Upon cancellation:
                    </p>
                    <ul>
                        <li>Your premium features will remain active until the end of your current billing period</li>
                        <li>No further charges will be made after cancellation</li>
                        <li>Your basic listing information will remain on the platform</li>
                        <li>You will not be charged for the next billing cycle</li>
                    </ul>
                    <p>
                        To cancel your subscription, go to your account settings or contact our support team at
                        <strong>support@boardgamecafefinder.com</strong>.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">4. Refund Eligibility</h2>
                    <p>We offer refunds under the following circumstances:</p>
                    <ul>
                        <li>
                            <strong>Within 14 days of first purchase:</strong> If you are not satisfied with the Service within
                            14 days of your initial subscription purchase, you may request a full refund.
                        </li>
                        <li>
                            <strong>Service disruption:</strong> If the Service experiences significant downtime or technical issues
                            that prevent you from using your premium features for an extended period, you may be eligible for a
                            prorated refund or credit.
                        </li>
                        <li>
                            <strong>Billing errors:</strong> If you were charged incorrectly or experienced duplicate charges,
                            we will issue a full refund for the erroneous charges.
                        </li>
                        <li>
                            <strong>Unauthorized charges:</strong> If a charge was made without your authorization, contact us
                            immediately and we will investigate and process a refund if applicable.
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">5. Non-Refundable Situations</h2>
                    <p>Refunds will generally not be issued in the following cases:</p>
                    <ul>
                        <li>After the 14-day satisfaction guarantee period for the initial purchase</li>
                        <li>For partial months of service after cancellation (your access continues until the end of the billing period)</li>
                        <li>If your account was suspended or terminated due to a violation of our Terms of Service</li>
                        <li>For services that have been fully delivered and utilized as intended</li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">6. How to Request a Refund</h2>
                    <p>To request a refund, please follow these steps:</p>
                    <ol>
                        <li>Send an email to <strong>support@boardgamecafefinder.com</strong> with the subject line "Refund Request"</li>
                        <li>Include your account email address and the reason for your refund request</li>
                        <li>Provide any relevant transaction or invoice details</li>
                    </ol>
                    <p>
                        We will review your request and respond within <strong>5 business days</strong>. If approved, the refund
                        will be processed to your original payment method within <strong>7-10 business days</strong>.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">7. Plan Changes</h2>
                    <p>
                        If you upgrade your plan, you will be charged the prorated difference for the remainder of your
                        current billing period. If you downgrade your plan:
                    </p>
                    <ul>
                        <li>The change will take effect at the start of your next billing cycle</li>
                        <li>You will retain access to your current plan's features until the end of the billing period</li>
                        <li>No refund will be issued for the difference between plans during the current period</li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">8. Chargebacks</h2>
                    <p>
                        We encourage you to contact us directly before initiating a chargeback with your payment provider.
                        We are committed to resolving any billing issues promptly and fairly. Filing a chargeback without
                        first contacting us may result in delays and potential account suspension.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">9. Changes to This Policy</h2>
                    <p>
                        We reserve the right to modify this Refund Policy at any time. Changes will be effective immediately
                        upon posting to this page. We will notify active subscribers of any material changes via email.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h4 mb-3">10. Contact Us</h2>
                    <p>If you have any questions about this Refund Policy, please contact us at:</p>
                    <ul class="list-unstyled">
                        <li><i class="bi bi-envelope me-2"></i> Email: support@boardgamecafefinder.com</li>
                    </ul>
                </div>
            </div>

            <div class="text-center mt-4">
                <a href="/" class="btn btn-primary">
                    <i class="bi bi-arrow-left me-2"></i>Back to Home
                </a>
            </div>
        </div>
    </div>
</div>
