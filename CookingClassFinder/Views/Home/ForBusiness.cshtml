@{
    ViewData["Title"] = "For Business";
}

<section class="hero-section text-center">
    <div class="container">
        <h1 class="display-4 fw-bold">List Your Cooking School</h1>
        <p class="lead">Reach thousands of food enthusiasts looking for their next culinary adventure</p>
    </div>
</section>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="card h-100 text-center p-4">
                        <div class="card-body">
                            <i class="bi bi-people-fill display-4 text-primary mb-3"></i>
                            <h4>Reach More Students</h4>
                            <p class="text-muted">Connect with food enthusiasts actively searching for cooking classes in your area.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 text-center p-4">
                        <div class="card-body">
                            <i class="bi bi-star-fill display-4 text-primary mb-3"></i>
                            <h4>Build Your Reputation</h4>
                            <p class="text-muted">Collect reviews from students and showcase your cooking school's excellence.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 text-center p-4">
                        <div class="card-body">
                            <i class="bi bi-graph-up-arrow display-4 text-primary mb-3"></i>
                            <h4>Grow Your Business</h4>
                            <p class="text-muted">Drive more bookings with premium features and featured placement.</p>
                        </div>
                    </div>
                </div>
            </div>

            <h2 class="text-center mb-4">Pricing Plans</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-header text-center py-3">
                            <h4 class="mb-0">Basic</h4>
                            <h2 class="my-3">Free</h2>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Basic listing</li>
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Contact information</li>
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Class listings</li>
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Review collection</li>
                            </ul>
                        </div>
                        <div class="card-footer">
                            <a href="#" class="btn btn-outline-primary w-100">Get Started</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-primary">
                        <div class="card-header text-center py-3 bg-primary text-white">
                            <h4 class="mb-0">Premium</h4>
                            <h2 class="my-3">$99/mo</h2>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Everything in Basic</li>
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Featured placement</li>
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Photo gallery</li>
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Class showcase</li>
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Priority support</li>
                            </ul>
                        </div>
                        <div class="card-footer">
                            <a href="#" class="btn btn-primary w-100">Subscribe</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100">
                        <div class="card-header text-center py-3">
                            <h4 class="mb-0">Featured</h4>
                            <h2 class="my-3">$199/mo</h2>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled">
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Everything in Premium</li>
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Homepage feature</li>
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Analytics dashboard</li>
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Booking integration</li>
                                <li class="mb-2"><i class="bi bi-check text-success me-2"></i>Dedicated support</li>
                            </ul>
                        </div>
                        <div class="card-footer">
                            <a href="#" class="btn btn-outline-primary w-100">Contact Sales</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
