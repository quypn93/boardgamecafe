@{
    ViewData["Title"] = "About Us";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="mb-4">About Cooking Class Finder</h1>

            <p class="lead">
                Cooking Class Finder is your ultimate guide to discovering culinary education experiences around the world.
            </p>

            <h3 class="mt-5">Our Mission</h3>
            <p>
                We believe that cooking is more than just a skill - it's an art form that brings people together.
                Our mission is to connect food enthusiasts with the best cooking classes, workshops, and culinary schools in their area.
            </p>

            <h3 class="mt-4">What We Offer</h3>
            <ul>
                <li>Comprehensive directory of cooking schools and classes</li>
                <li>Detailed reviews and ratings from real students</li>
                <li>Filter by cuisine type, difficulty level, and more</li>
                <li>Information about class schedules, pricing, and instructors</li>
                <li>Easy booking and reservation options</li>
            </ul>

            <h3 class="mt-4">For Cooking Schools</h3>
            <p>
                If you operate a cooking school or offer culinary classes, we'd love to feature you on our platform.
                <a asp-controller="Home" asp-action="ForBusiness">Learn more about listing your school</a>.
            </p>
        </div>
    </div>
</div>
