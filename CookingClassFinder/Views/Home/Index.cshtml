@model SchoolSearchPagedResult
@{
    ViewData["Title"] = "Find Cooking Classes Near You";
}

<section class="hero-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h1 class="display-4 fw-bold mb-3">Discover Cooking Classes</h1>
                <p class="lead mb-4">Learn from expert chefs. Master new cuisines. Find your next culinary adventure.</p>

                <form method="get" class="card p-4 shadow">
                    <div class="row g-3">
                        <div class="col-md-5">
                            <input type="text" name="query" class="form-control form-control-lg" placeholder="Search classes or schools..." value="@ViewBag.Query" />
                        </div>
                        <div class="col-md-3">
                            <select name="city" class="form-select form-select-lg">
                                <option value="">All Cities</option>
                                @foreach (var city in (List<string>)ViewBag.Cities)
                                {
                                    <option value="@city" selected="@(ViewBag.City == city)">@city</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <select name="cuisine" class="form-select form-select-lg">
                                <option value="">All Cuisines</option>
                                @foreach (var cuisine in (List<string>)ViewBag.Cuisines)
                                {
                                    <option value="@cuisine" selected="@(ViewBag.Cuisine == cuisine)">@cuisine</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-1">
                            <button type="submit" class="btn btn-primary btn-lg w-100">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<div class="container my-5">
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <h2>
                    @if (!string.IsNullOrEmpty(ViewBag.Query) || !string.IsNullOrEmpty(ViewBag.City) || !string.IsNullOrEmpty(ViewBag.Cuisine))
                    {
                        <span>Search Results</span>
                        <small class="text-muted">(@Model.TotalCount found)</small>
                    }
                    else
                    {
                        <span>Featured Cooking Schools</span>
                    }
                </h2>
                <div class="text-muted">
                    <i class="bi bi-building me-1"></i>@ViewBag.TotalSchools schools
                    <i class="bi bi-book ms-3 me-1"></i>@ViewBag.TotalClasses classes
                </div>
            </div>
        </div>
    </div>

    @if (Model.Schools.Any())
    {
        <div class="row g-4">
            @foreach (var school in Model.Schools)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100">
                        <div class="position-relative">
                            <img src="@(school.LocalImagePath ?? "/images/placeholder.jpg")"
                                 class="card-img-top"
                                 alt="@school.Name"
                                 style="height: 200px; object-fit: cover;">
                            @if (school.IsPremium)
                            {
                                <span class="badge bg-warning position-absolute top-0 end-0 m-2">
                                    <i class="bi bi-star-fill"></i> Premium
                                </span>
                            }
                        </div>
                        <div class="card-body">
                            <h5 class="card-title">@school.Name</h5>
                            <p class="text-muted mb-2">
                                <i class="bi bi-geo-alt"></i> @school.City, @school.Country
                            </p>
                            @if (school.AverageRating.HasValue)
                            {
                                <div class="mb-2">
                                    <span class="rating">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi @(i <= school.AverageRating ? "bi-star-fill" : "bi-star")"></i>
                                        }
                                    </span>
                                    <span class="text-muted">(@school.TotalReviews reviews)</span>
                                </div>
                            }
                            <div class="d-flex flex-wrap gap-1 mb-3">
                                @foreach (var cuisine in school.CuisineSpecialties.Take(3))
                                {
                                    <span class="badge bg-light text-dark">@cuisine</span>
                                }
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted">
                                    <i class="bi bi-book"></i> @school.TotalClasses classes
                                </span>
                                @if (school.LowestPrice.HasValue)
                                {
                                    <span class="fw-bold text-primary">From $@school.LowestPrice</span>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-white">
                            <a asp-controller="School" asp-action="Details" asp-route-slug="@school.Slug"
                               class="btn btn-outline-primary w-100">View Classes</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-5">
                <ul class="pagination justify-content-center">
                    @if (Model.HasPreviousPage)
                    {
                        <li class="page-item">
                            <a class="page-link" href="?page=@(Model.Page - 1)&query=@ViewBag.Query&city=@ViewBag.City&cuisine=@ViewBag.Cuisine">Previous</a>
                        </li>
                    }
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" href="?page=@i&query=@ViewBag.Query&city=@ViewBag.City&cuisine=@ViewBag.Cuisine">@i</a>
                        </li>
                    }
                    @if (Model.HasNextPage)
                    {
                        <li class="page-item">
                            <a class="page-link" href="?page=@(Model.Page + 1)&query=@ViewBag.Query&city=@ViewBag.City&cuisine=@ViewBag.Cuisine">Next</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-search display-1 text-muted"></i>
            <h3 class="mt-3">No cooking schools found</h3>
            <p class="text-muted">Try adjusting your search criteria or browse all schools.</p>
            <a href="/" class="btn btn-primary">View All Schools</a>
        </div>
    }
</div>
