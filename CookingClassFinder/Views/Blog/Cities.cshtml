@model IEnumerable<CityBlogItem>
@{
    ViewData["Title"] = "City Guides";
}

<div class="container my-5">
    <h1>City Guides</h1>
    <p class="lead text-muted">Discover the best cooking classes in cities around the world</p>

    <div class="row">
        @foreach (var city in Model)
        {
            <div class="col-md-4 mb-4">
                <a asp-action="CityGuide" asp-route-slug="@city.Slug" class="text-decoration-none">
                    <div class="card h-100 city-card">
                        @if (!string.IsNullOrEmpty(city.ImageUrl))
                        {
                            <img src="@city.ImageUrl" class="card-img-top" style="height: 180px; object-fit: cover;" alt="@city.Name">
                        }
                        else
                        {
                            <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 180px;">
                                <i class="bi bi-geo-alt display-3 text-white"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title text-dark">@city.Name</h5>
                            <p class="text-muted mb-1">@city.Country</p>
                            <small class="text-muted">@city.SchoolCount cooking schools</small>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-geo-alt display-1 text-muted"></i>
            <p class="text-muted mt-3">No city guides available yet.</p>
        </div>
    }
</div>

<style>
    .city-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .city-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    }
</style>
