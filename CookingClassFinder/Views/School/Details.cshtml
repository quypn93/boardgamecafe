@model CookingSchool
@{
    ViewData["Title"] = Model.Name;
}

<div class="container my-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active">@Model.Name</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <h1>@Model.Name</h1>
            <p class="text-muted">
                <i class="bi bi-geo-alt"></i> @Model.Address, @Model.City, @Model.Country
            </p>

            @if (Model.AverageRating.HasValue)
            {
                <div class="mb-3">
                    <span class="rating">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="bi @(i <= Model.AverageRating ? "bi-star-fill" : "bi-star")"></i>
                        }
                    </span>
                    <span class="ms-2">@Model.AverageRating.Value.ToString("F1") (@Model.TotalReviews reviews)</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">About</h5>
                        <p>@Model.Description</p>
                    </div>
                </div>
            }

            <h3 class="mb-3">Available Classes (@Model.Classes.Count)</h3>
            @foreach (var cookingClass in Model.Classes)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h5 class="card-title">@cookingClass.Name</h5>
                                <span class="badge @cookingClass.GetDifficultyBadgeClass()">@cookingClass.DifficultyLevel</span>
                                <span class="badge bg-secondary">@cookingClass.CuisineType</span>
                            </div>
                            <div class="text-end">
                                @if (cookingClass.PricePerPerson.HasValue)
                                {
                                    <h5 class="text-primary">$@cookingClass.PricePerPerson/person</h5>
                                }
                            </div>
                        </div>
                        <p class="text-muted mt-2">
                            <i class="bi bi-clock"></i> @cookingClass.GetDurationDisplay()
                            <i class="bi bi-people ms-3"></i> @cookingClass.GetStudentRange()
                        </p>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var tag in cookingClass.GetFeatureTags().Take(5))
                            {
                                <span class="badge bg-light text-dark">@tag</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-body">
                    <h5 class="card-title">Contact Information</h5>
                    <ul class="list-unstyled">
                        @if (!string.IsNullOrEmpty(Model.Phone))
                        {
                            <li class="mb-2"><i class="bi bi-telephone me-2"></i>@Model.Phone</li>
                        }
                        @if (!string.IsNullOrEmpty(Model.Email))
                        {
                            <li class="mb-2"><i class="bi bi-envelope me-2"></i>@Model.Email</li>
                        }
                        @if (!string.IsNullOrEmpty(Model.Website))
                        {
                            <li class="mb-2">
                                <i class="bi bi-globe me-2"></i>
                                <a href="@Model.Website" target="_blank" rel="noopener">Visit Website</a>
                            </li>
                        }
                    </ul>
                    @if (!string.IsNullOrEmpty(Model.BookingUrl))
                    {
                        <a href="@Model.BookingUrl" target="_blank" rel="noopener" class="btn btn-primary w-100">
                            Book a Class
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
