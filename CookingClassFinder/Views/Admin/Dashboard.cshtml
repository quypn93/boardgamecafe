@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0">Total Schools</h6>
                        <h2 class="mb-0">@(ViewBag.TotalSchools ?? 0)</h2>
                    </div>
                    <i class="bi bi-building fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0">Total Classes</h6>
                        <h2 class="mb-0">@(ViewBag.TotalClasses ?? 0)</h2>
                    </div>
                    <i class="bi bi-mortarboard fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0">Total Reviews</h6>
                        <h2 class="mb-0">@(ViewBag.TotalReviews ?? 0)</h2>
                    </div>
                    <i class="bi bi-star fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0">Total Users</h6>
                        <h2 class="mb-0">@(ViewBag.TotalUsers ?? 0)</h2>
                    </div>
                    <i class="bi bi-people fs-1 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Recent Schools</h5>
                <a asp-action="Schools" class="btn btn-sm btn-outline-primary">View All</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>City</th>
                                <th>Classes</th>
                                <th>Rating</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentSchools != null)
                            {
                                foreach (var school in ViewBag.RecentSchools)
                                {
                                    <tr>
                                        <td>@school.Name</td>
                                        <td>@school.City</td>
                                        <td>@school.TotalClasses</td>
                                        <td>
                                            @if (school.AverageRating.HasValue)
                                            {
                                                <span>@school.AverageRating.Value.ToString("F1") <i class="bi bi-star-fill text-warning"></i></span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">N/A</span>
                                            }
                                        </td>
                                        <td>
                                            @if (school.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-action="CreateSchool" class="btn btn-outline-primary">
                        <i class="bi bi-plus-circle me-2"></i>Add New School
                    </a>
                    <a asp-action="CreateClass" class="btn btn-outline-success">
                        <i class="bi bi-plus-circle me-2"></i>Add New Class
                    </a>
                    <a asp-action="Reviews" class="btn btn-outline-warning">
                        <i class="bi bi-star me-2"></i>Moderate Reviews
                    </a>
                    <a asp-action="CrawlStatus" class="btn btn-outline-info">
                        <i class="bi bi-arrow-repeat me-2"></i>Crawl Status
                    </a>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header">
                <h5 class="mb-0">Pending Reviews</h5>
            </div>
            <div class="card-body">
                @if (ViewBag.PendingReviews != null && ViewBag.PendingReviews > 0)
                {
                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        @ViewBag.PendingReviews reviews pending approval
                        <a asp-action="Reviews" asp-route-status="pending" class="alert-link">Review now</a>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No pending reviews</p>
                }
            </div>
        </div>
    </div>
</div>
