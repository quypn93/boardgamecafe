@model IEnumerable<BlogPost>
@{
    ViewData["Title"] = "Blog Posts";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0">Manage Blog Posts</h4>
    </div>
    <a asp-action="CreateBlogPost" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>New Post
    </a>
</div>

<div class="card">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-newspaper display-1 text-muted"></i>
                <p class="text-muted mt-3">No blog posts yet</p>
                <a asp-action="CreateBlogPost" class="btn btn-primary">Create Your First Post</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Author</th>
                            <th>Cuisine</th>
                            <th>Views</th>
                            <th>Created</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var post in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@post.Title</strong>
                                    @if (post.IsFeatured)
                                    {
                                        <span class="badge bg-warning ms-1">Featured</span>
                                    }
                                </td>
                                <td>@post.Author</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(post.RelatedCuisine))
                                    {
                                        <span class="badge bg-secondary">@post.RelatedCuisine</span>
                                    }
                                </td>
                                <td>@post.ViewCount</td>
                                <td>@post.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @if (post.IsPublished)
                                    {
                                        <span class="badge bg-success">Published</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Draft</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditBlogPost" asp-route-id="@post.Id" class="btn btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-controller="Blog" asp-action="Post" asp-route-slug="@post.Slug" target="_blank" class="btn btn-outline-secondary" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-danger" onclick="confirmDelete(@post.Id, '@post.Title')" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(id, title) {
            if (confirm(`Are you sure you want to delete "${title}"?`)) {
                window.location.href = `/Admin/DeleteBlogPost/${id}`;
            }
        }
    </script>
}
