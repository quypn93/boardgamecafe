@{
    ViewData["Title"] = "Claim Your Listing";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1>Claim Your Cooking School</h1>
            <p class="lead text-muted">Already listed? Claim ownership to manage your school's information</p>

            <div class="card">
                <div class="card-body">
                    <form asp-action="SubmitClaim" method="post">
                        <div class="mb-3">
                            <label class="form-label">Search for Your School *</label>
                            <input type="text" id="schoolSearch" name="SchoolName" class="form-control" placeholder="Type your school name..." required />
                            <input type="hidden" name="SchoolId" id="selectedSchoolId" />
                        </div>

                        <div id="searchResults" class="list-group mb-3" style="display: none;">
                        </div>

                        <hr class="my-4" />
                        <h5 class="mb-3">Your Information</h5>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Your Name *</label>
                                <input type="text" name="ContactName" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Job Title</label>
                                <input type="text" name="JobTitle" class="form-control" placeholder="e.g., Owner, Manager" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email *</label>
                                <input type="email" name="Email" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Phone *</label>
                                <input type="tel" name="Phone" class="form-control" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Verification Method *</label>
                            <select name="VerificationMethod" class="form-select" required>
                                <option value="">Select how you'd like to verify ownership</option>
                                <option value="phone">Phone call to business number</option>
                                <option value="email">Email to business domain</option>
                                <option value="document">Upload business document</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Additional Notes</label>
                            <textarea name="Notes" class="form-control" rows="3" placeholder="Any additional information to help verify your ownership..."></textarea>
                        </div>

                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" id="agreeTerms" required />
                            <label class="form-check-label" for="agreeTerms">
                                I confirm that I am authorized to manage this business listing
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg">Submit Claim Request</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Simple school search functionality
        const searchInput = document.getElementById('schoolSearch');
        const searchResults = document.getElementById('searchResults');

        searchInput.addEventListener('input', async function() {
            const query = this.value;
            if (query.length < 2) {
                searchResults.style.display = 'none';
                return;
            }

            try {
                const response = await fetch(`/api/schools/search?q=${encodeURIComponent(query)}`);
                const schools = await response.json();

                if (schools.length > 0) {
                    searchResults.innerHTML = schools.map(s =>
                        `<a href="#" class="list-group-item list-group-item-action" data-id="${s.id}" data-name="${s.name}">
                            <strong>${s.name}</strong><br>
                            <small class="text-muted">${s.city}, ${s.country}</small>
                        </a>`
                    ).join('');
                    searchResults.style.display = 'block';
                } else {
                    searchResults.innerHTML = '<div class="list-group-item text-muted">No schools found</div>';
                    searchResults.style.display = 'block';
                }
            } catch (err) {
                console.error('Search error:', err);
            }
        });

        searchResults.addEventListener('click', function(e) {
            if (e.target.closest('.list-group-item-action')) {
                e.preventDefault();
                const item = e.target.closest('.list-group-item-action');
                searchInput.value = item.dataset.name;
                document.getElementById('selectedSchoolId').value = item.dataset.id;
                searchResults.style.display = 'none';
            }
        });
    </script>
}
